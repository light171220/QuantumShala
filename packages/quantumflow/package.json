{
  "name": "quantumflow",
  "version": "0.1.0",
  "description": "TypeScript-native quantum machine learning library with automatic differentiation",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./core": {
      "import": "./dist/core/index.mjs",
      "require": "./dist/core/index.js",
      "types": "./dist/core/index.d.ts"
    },
    "./autodiff": {
      "import": "./dist/autodiff/index.mjs",
      "require": "./dist/autodiff/index.js",
      "types": "./dist/autodiff/index.d.ts"
    },
    "./circuit": {
      "import": "./dist/circuit/index.mjs",
      "require": "./dist/circuit/index.js",
      "types": "./dist/circuit/index.d.ts"
    },
    "./devices": {
      "import": "./dist/devices/index.mjs",
      "require": "./dist/devices/index.js",
      "types": "./dist/devices/index.d.ts"
    },
    "./transforms": {
      "import": "./dist/transforms/index.mjs",
      "require": "./dist/transforms/index.js",
      "types": "./dist/transforms/index.d.ts"
    },
    "./templates": {
      "import": "./dist/templates/index.mjs",
      "require": "./dist/templates/index.js",
      "types": "./dist/templates/index.d.ts"
    },
    "./nn": {
      "import": "./dist/nn/index.mjs",
      "require": "./dist/nn/index.js",
      "types": "./dist/nn/index.d.ts"
    },
    "./optim": {
      "import": "./dist/optim/index.mjs",
      "require": "./dist/optim/index.js",
      "types": "./dist/optim/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "quantum",
    "quantum-computing",
    "quantum-machine-learning",
    "qml",
    "autodiff",
    "automatic-differentiation",
    "variational-quantum",
    "vqe",
    "qaoa",
    "pennylane-alternative",
    "typescript",
    "webgpu"
  ],
  "author": "QuantumShala",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/quantumshala/quantumflow"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false
}
