      "id": "q1",
      "type": "multiple-choice",
      "points": 25,
      "question": "The QFT of |j⟩ is:",
      "options": [
        {"id": "a", "text": "Σₖ e^(2πijk/N)|k⟩"},
        {"id": "b", "text": "(1/√N) Σₖ e^(2πijk/N)|k⟩"},
        {"id": "c", "text": "(1/N) Σₖ e^(2πijk/N)|k⟩"},
        {"id": "d", "text": "e^(2πij/N)|j⟩"}
      ],
      "correctAnswer": "b",
      "explanation": "QFT|j⟩ = (1/√N) Σₖ e^(2πijk/N)|k⟩ includes the normalization factor 1/√N."
    },
    {
      "id": "q2",
      "type": "multiple-choice",
      "points": 25,
      "question": "The gate complexity of QFT on n qubits is:",
      "options": [
        {"id": "a", "text": "O(n)"},
        {"id": "b", "text": "O(n²)"},
        {"id": "c", "text": "O(2^n)"},
        {"id": "d", "text": "O(n log n)"}
      ],
      "correctAnswer": "b",
      "explanation": "QFT requires O(n²) gates, which is exponentially faster than classical FFT's O(N log N) = O(n·2^n)."
    },
    {
      "id": "q3",
      "type": "true-false",
      "points": 25,
      "question": "The QFT matrix is unitary.",
      "options": [
        {"id": "true", "text": "True"},
        {"id": "false", "text": "False"}
      ],
      "correctAnswer": "true",
      "explanation": "QFT is unitary: QFT† QFT = I."
    },
    {
      "id": "q4",
      "type": "multiple-choice",
      "points": 25,
      "question": "For n=2 qubits, N = ?",
      "options": [
        {"id": "a", "text": "2"},
        {"id": "b", "text": "4"},
        {"id": "c", "text": "8"},
        {"id": "d", "text": "16"}
      ],
      "correctAnswer": "b",
      "explanation": "N = 2^n = 2² = 4."
    }
  ]
