  "questions": [
    {
      "id": "q1",
      "type": "multiple-choice",
      "points": 20,
      "question": "What is CNOT|11⟩?",
      "options": [
        {"id": "a", "text": "|00⟩"},
        {"id": "b", "text": "|01⟩"},
        {"id": "c", "text": "|10⟩"},
        {"id": "d", "text": "|11⟩"}
      ],
      "correctAnswer": "c",
      "explanation": "CNOT flips the target when control is |1⟩. |11⟩ → |10⟩."
    },
    {
      "id": "q2",
      "type": "true-false",
      "points": 20,
      "question": "CNOT² = I (CNOT is self-inverse).",
      "options": [
        {"id": "true", "text": "True"},
        {"id": "false", "text": "False"}
      ],
      "correctAnswer": "true",
      "explanation": "CNOT applied twice returns to the original state."
    },
    {
      "id": "q3",
      "type": "multiple-choice",
      "points": 20,
      "question": "To create |Φ+⟩ from |00⟩, we apply:",
      "options": [
        {"id": "a", "text": "CNOT only"},
        {"id": "b", "text": "H on qubit 0, then CNOT"},
        {"id": "c", "text": "H on qubit 1, then CNOT"},
        {"id": "d", "text": "CNOT, then H"}
      ],
      "correctAnswer": "c",
      "explanation": "H creates superposition on control qubit, CNOT entangles."
    },
    {
      "id": "q4",
      "type": "multiple-choice",
      "points": 20,
      "question": "How is CZ related to CNOT?",
      "options": [
        {"id": "a", "text": "CZ = CNOT"},
        {"id": "b", "text": "CZ = (I⊗H)·CNOT·(I⊗H)"},
        {"id": "c", "text": "CZ = CNOT²"},
        {"id": "d", "text": "No relation"}
      ],
      "correctAnswer": "b",
      "explanation": "Hadamards on the target convert CNOT to CZ."
    },
    {
      "id": "q5",
      "type": "multiple-choice",
      "points": 20,
      "question": "CNOT on |+0⟩ produces:",
      "options": [
        {"id": "a", "text": "A product state"},
        {"id": "b", "text": "An entangled state"},
        {"id": "c", "text": "|+0⟩ unchanged"},
        {"id": "d", "text": "|+1⟩"}
      ],
      "correctAnswer": "b",
      "explanation": "CNOT on superposition creates entanglement: |+0⟩ → (|00⟩+|11⟩)/√2."
    }
  ]
