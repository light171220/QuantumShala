{
  "exerciseId": "01-10-03-qml-data-encoding-exercises",
  "title": "Exercises: Data Encoding for QML",
  "exercises": [
    {
      "id": "ex1",
      "title": "Basis Encoding Implementation",
      "type": "coding",
      "difficulty": "beginner",
      "points": 25,
      "description": "Implement basis encoding for integer data.",
      "tasks": [
        "Calculate required qubits for max value",
        "Convert integers to binary",
        "Create circuit with X gates",
        "Verify with simulation",
        "Extend to encode superposition of values"
      ],
      "expectedOutput": "Basis encoding circuit",
      "hints": [
        "n qubits = ceil(log2(max_val + 1))",
        "X gate flips |0⟩ to |1⟩",
        "Check binary representation",
        "Measure to verify"
      ]
    },
    {
      "id": "ex2",
      "title": "Angle Encoding Circuit",
      "type": "coding",
      "difficulty": "intermediate",
      "points": 25,
      "description": "Build angle encoding for feature vectors.",
      "tasks": [
        "Encode each feature as Ry rotation",
        "Scale features to appropriate range",
        "Build circuit for input vector",
        "Compute resulting quantum state",
        "Visualize on Bloch sphere"
      ],
      "expectedOutput": "Angle encoding with visualization",
      "hints": [
        "Ry(θ)|0⟩ = cos(θ/2)|0⟩ + sin(θ/2)|1⟩",
        "Scale x to [0, π] or [-π, π]",
        "One qubit per feature",
        "Use qiskit visualization"
      ]
    },
    {
      "id": "ex3",
      "title": "ZZ Feature Map Builder",
      "type": "coding",
      "difficulty": "advanced",
      "points": 25,
      "description": "Implement the ZZ feature map encoding.",
      "tasks": [
        "Create layer of Hadamards",
        "Add Z rotations with feature values",
        "Add ZZ interactions for feature pairs",
        "Stack multiple layers",
        "Compute resulting feature map"
      ],
      "expectedOutput": "ZZ feature map circuit",
      "hints": [
        "H gates create superposition",
        "Rz(2x) for Z rotations",
        "CZ or CNOT+Rz+CNOT for ZZ",
        "2-3 layers typical"
      ]
    },
    {
      "id": "ex4",
      "title": "Encoding Comparison Study",
      "type": "coding",
      "difficulty": "intermediate",
      "points": 25,
      "description": "Compare different encoding methods on a classification task.",
      "tasks": [
        "Prepare simple 2D dataset",
        "Implement 3 different encodings",
        "Train same variational classifier with each",
        "Compare accuracy and training curves",
        "Analyze resource requirements"
      ],
      "expectedOutput": "Encoding comparison report",
      "hints": [
        "Angle, ZZ, and amplitude encodings",
        "Use same circuit structure after encoding",
        "Track qubit count and depth",
        "Multiple runs for statistics"
      ]
    }
  ]
}
