{
  "exerciseId": "01-10-06-qml-applications-exercises",
  "title": "Exercises: QML Applications",
  "exercises": [
    {
      "id": "ex1",
      "title": "Simple VQE Implementation",
      "type": "coding",
      "difficulty": "advanced",
      "points": 25,
      "description": "Implement VQE for a simple molecular Hamiltonian.",
      "tasks": [
        "Define H2 Hamiltonian in Pauli basis",
        "Build parameterized ansatz",
        "Implement energy expectation measurement",
        "Optimize parameters to find ground state",
        "Plot energy convergence"
      ],
      "expectedOutput": "VQE ground state energy",
      "hints": [
        "H2: H = c0*I + c1*Z0 + c2*Z1 + c3*Z0Z1 + c4*X0X1 + c5*Y0Y1",
        "Use 2-qubit ansatz",
        "Measure each Pauli term separately",
        "Compare to exact ground state"
      ]
    },
    {
      "id": "ex2",
      "title": "QAOA for MaxCut",
      "type": "coding",
      "difficulty": "advanced",
      "points": 25,
      "description": "Implement QAOA for the MaxCut problem on a small graph.",
      "tasks": [
        "Define graph and cost Hamiltonian",
        "Implement QAOA circuit with p layers",
        "Optimize gamma and beta parameters",
        "Sample solutions from optimized circuit",
        "Compare to brute force optimal"
      ],
      "expectedOutput": "QAOA MaxCut solution",
      "hints": [
        "Cost: H_C = Σ (1-ZiZj)/2 for edges",
        "Mixer: H_B = Σ Xi",
        "Start with p=1, increase if needed",
        "Check approximation ratio"
      ]
    },
    {
      "id": "ex3",
      "title": "Quantum Classifier Benchmark",
      "type": "coding",
      "difficulty": "intermediate",
      "points": 25,
      "description": "Compare quantum and classical classifiers on a simple dataset.",
      "tasks": [
        "Generate 2D classification dataset",
        "Implement variational quantum classifier",
        "Train classical SVM for comparison",
        "Compare accuracy and training time",
        "Analyze when each performs better"
      ],
      "expectedOutput": "Classifier comparison report",
      "hints": [
        "Use moons or circles dataset",
        "4-6 qubits sufficient for 2D",
        "Fair comparison: same training data",
        "Report confidence intervals"
      ]
    },
    {
      "id": "ex4",
      "title": "QCBM Distribution Learning",
      "type": "coding",
      "difficulty": "advanced",
      "points": 25,
      "description": "Train a Quantum Circuit Born Machine to learn a simple distribution.",
      "tasks": [
        "Define target discrete distribution",
        "Build QCBM ansatz",
        "Implement MMD or KL divergence loss",
        "Train to match target distribution",
        "Sample and verify match"
      ],
      "expectedOutput": "Trained generative model",
      "hints": [
        "Start with 3-4 qubit distribution",
        "MMD: Maximum Mean Discrepancy",
        "Need many samples for loss estimate",
        "Histogram comparison for verification"
      ]
    }
  ]
}
