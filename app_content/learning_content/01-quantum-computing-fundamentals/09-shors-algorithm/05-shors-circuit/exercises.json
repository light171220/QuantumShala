{
  "exerciseId": "01-09-05-shors-circuit-exercises",
  "title": "Exercises: Shor's Algorithm Circuit",
  "exercises": [
    {
      "id": "ex1",
      "title": "Register Size Calculator",
      "type": "coding",
      "difficulty": "intermediate",
      "points": 25,
      "description": "Build a function to calculate optimal register sizes for Shor's algorithm.",
      "tasks": [
        "Input: number N to factor",
        "Calculate control register size (2n qubits)",
        "Calculate target register size (n qubits)",
        "Estimate total qubit count including ancilla",
        "Output a summary of requirements"
      ],
      "expectedOutput": "Register size analysis",
      "hints": [
        "n = ceil(log2(N))",
        "Control needs 2n for precision",
        "Ancilla roughly doubles qubit count",
        "Consider practical limits"
      ]
    },
    {
      "id": "ex2",
      "title": "Circuit Diagram Generator",
      "type": "coding",
      "difficulty": "advanced",
      "points": 25,
      "description": "Create a visual representation of Shor's circuit structure.",
      "tasks": [
        "Generate ASCII circuit diagram",
        "Show Hadamard layer",
        "Indicate controlled modular operations",
        "Show QFT section",
        "Mark measurement points"
      ],
      "expectedOutput": "ASCII circuit diagram",
      "hints": [
        "Use box-drawing characters",
        "Label each stage clearly",
        "Show control/target separation",
        "Indicate gate types"
      ]
    },
    {
      "id": "ex3",
      "title": "Gate Count Estimator",
      "type": "coding",
      "difficulty": "intermediate",
      "points": 25,
      "description": "Estimate the number of gates needed for Shor's algorithm.",
      "tasks": [
        "Count Hadamard gates",
        "Estimate QFT gate count",
        "Estimate modular exponentiation gates",
        "Calculate total gate count",
        "Plot scaling with input size"
      ],
      "expectedOutput": "Gate count analysis with graph",
      "hints": [
        "QFT: O(n²) controlled rotations",
        "Mod exp: O(n³) elementary gates",
        "Use specific formulas for counts",
        "matplotlib for visualization"
      ]
    },
    {
      "id": "ex4",
      "title": "Period Extraction Simulator",
      "type": "coding",
      "difficulty": "advanced",
      "points": 25,
      "description": "Simulate the measurement and period extraction process.",
      "tasks": [
        "Generate measurement outcomes for given period",
        "Apply continued fractions algorithm",
        "Extract candidate periods",
        "Verify period correctness",
        "Calculate success probability"
      ],
      "expectedOutput": "Period extraction from measurements",
      "hints": [
        "Peaks at m where m/2^2n ≈ k/r",
        "Continued fractions for rational approximation",
        "Multiple measurements may be needed",
        "Verify: a^r mod N = 1"
      ]
    }
  ]
