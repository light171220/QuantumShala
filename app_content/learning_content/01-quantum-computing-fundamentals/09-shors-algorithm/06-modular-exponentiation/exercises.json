      "title": "Repeated Squaring Implementation",
      "type": "coding",
      "difficulty": "intermediate",
      "points": 25,
      "description": "Implement classical modular exponentiation using repeated squaring.",
      "tasks": [
        "Write function for a^x mod N",
        "Use binary expansion of x",
        "Precompute powers of a",
        "Count number of multiplications",
        "Compare to naive approach"
      ],
      "expectedOutput": "Efficient modular exponentiation",
      "hints": [
        "x & 1 checks if x is odd",
        "x >> 1 divides x by 2",
        "Track multiplication count",
        "Verify with small examples"
      ]
    },
    {
      "id": "ex2",
      "title": "Power Precomputation Table",
      "type": "coding",
      "difficulty": "intermediate",
      "points": 25,
      "description": "Generate the precomputed powers needed for Shor's circuit.",
      "tasks": [
        "Input: a, N, and number of control qubits",
        "Compute a^(2^i) mod N for each i",
        "Verify the period in the sequence",
        "Output formatted table",
        "Check for patterns"
      ],
      "expectedOutput": "Table of precomputed powers",
      "hints": [
        "Use repeated squaring",
        "Powers cycle with period r",
        "2n control qubits needed",
        "Useful for circuit design"
      ]
    },
    {
      "id": "ex3",
      "title": "Reversible Adder Design",
      "type": "coding",
      "difficulty": "advanced",
      "points": 25,
      "description": "Design a reversible addition circuit using CNOT and Toffoli gates.",
      "tasks": [
        "Implement ripple-carry adder",
        "Ensure all operations are reversible",
        "Track ancilla qubit usage",
        "Calculate gate count",
        "Simulate on small inputs"
      ],
      "expectedOutput": "Reversible adder circuit",
      "hints": [
        "Full adder: sum and carry",
        "Toffoli for AND operations",
        "CNOT for XOR operations",
        "Uncompute intermediate values"
      ]
    },
    {
      "id": "ex4",
      "title": "Modular Multiplication Complexity",
      "type": "coding",
      "difficulty": "advanced",
      "points": 25,
      "description": "Analyze and visualize the complexity of modular multiplication circuits.",
      "tasks": [
        "Calculate gate count for n-bit multiplication",
        "Include modular reduction overhead",
        "Compare schoolbook vs optimized methods",
        "Plot scaling with n",
        "Estimate for RSA-2048"
      ],
      "expectedOutput": "Complexity analysis with visualization",
      "hints": [
        "Schoolbook: O(n²) gates",
        "Karatsuba: O(n^1.58) gates",
