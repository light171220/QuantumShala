{
  "exerciseId": "04-10-02-superconducting-qec-exercises",
  "title": "Exercises: QEC on Superconducting Qubits",
  "exercises": [
    {
      "id": "ex1",
      "title": "Chip Layout Generator",
      "type": "coding",
      "difficulty": "intermediate",
      "points": 25,
      "description": "Generate surface code chip layouts for superconducting processors.",
      "tasks": [
        "Create 2D grid for given code distance d",
        "Place data qubits at vertices",
        "Place X and Z ancilla qubits",
        "Generate coupling map (edges)",
        "Visualize the layout"
      ],
      "expectedOutput": "Chip layout visualization",
      "hints": [
        "Data: d² qubits",
        "Ancillas: (d-1)² + d² - 1 qubits",
        "Checkerboard pattern for X vs Z",
        "Use matplotlib or networkx for visualization"
      ]
    },
    {
      "id": "ex2",
      "title": "Frequency Allocator",
      "type": "coding",
      "difficulty": "intermediate",
      "points": 25,
      "description": "Assign frequencies to qubits avoiding collisions.",
      "tasks": [
        "Input: chip coupling graph",
        "Assign frequencies from available set",
        "Ensure no adjacent qubits share frequency",
        "Minimize number of distinct frequencies",
        "Check for ZZ coupling violations"
      ],
      "expectedOutput": "Frequency allocation tool",
      "hints": [
        "Graph coloring problem",
        "4-5 frequencies typically sufficient",
        "Greedy or backtracking algorithm",
        "Verify no adjacent pairs collide"
      ]
    },
    {
      "id": "ex3",
      "title": "Syndrome Circuit Scheduler",
      "type": "coding",
      "difficulty": "advanced",
      "points": 25,
      "description": "Schedule gates in syndrome extraction to avoid crosstalk.",
      "tasks": [
        "List all gates in syndrome circuit",
        "Identify conflicting gate pairs (crosstalk)",
        "Schedule gates to minimize conflicts",
        "Calculate total circuit depth",
        "Compare to naive parallel schedule"
      ],
      "expectedOutput": "Optimized gate schedule",
      "hints": [
        "Conflict: gates on nearby qubits in parallel",
        "Use list scheduling or constraint solver",
        "Trade-off: depth vs crosstalk",
        "Surface code has natural 4-layer structure"
      ]
    },
    {
      "id": "ex4",
      "title": "Leakage Simulator",
      "type": "coding",
      "difficulty": "advanced",
      "points": 25,
      "description": "Simulate leakage effects in QEC cycles.",
      "tasks": [
        "Model 3-level qubits (|0⟩, |1⟩, |2⟩)",
        "Include leakage probability per gate",
        "Simulate QEC cycles with leakage",
        "Implement leakage detection",
        "Compare logical error rate with/without LRU"
      ],
      "expectedOutput": "Leakage simulation tool",
      "hints": [
        "Track population in |2⟩ state",
        "Leakage rate: ~0.1% per two-qubit gate",
        "Leakage causes correlated syndrome errors",
        "LRU: measure and reset if leaked"
      ]
    }
  ]
}
