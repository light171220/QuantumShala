{
  "exerciseId": "07-09-01-router-fundamentals-exercises",
  "title": "Exercises: Quantum Router Fundamentals",
  "exercises": [
    {
      "id": "ex1",
      "title": "Router Mode Selector",
      "type": "coding",
      "difficulty": "beginner",
      "points": 20,
      "description": "Implement a system to select the appropriate routing mode.",
      "tasks": [
        "Define routing modes (optical, store-forward, teleportation)",
        "Check available resources for each mode",
        "Select optimal mode based on conditions",
        "Handle fallback when preferred mode unavailable",
        "Generate routing decision report"
      ],
      "expectedOutput": "Routing mode selection system",
      "hints": [
        "Optical switch is fastest if path exists",
        "Teleportation needs pre-shared entanglement",
        "Store-forward needs available memory",
        "Consider fidelity requirements"
      ]
    },
    {
      "id": "ex2",
      "title": "Switch Matrix Configurator",
      "type": "coding",
      "difficulty": "intermediate",
      "points": 30,
      "description": "Configure optical switch matrix for quantum routing.",
      "tasks": [
        "Model N×N optical switch matrix",
        "Implement switch configuration",
        "Handle port conflicts",
        "Calculate switch loss",
        "Optimize multi-path routing"
      ],
      "expectedOutput": "Optical switch matrix configurator",
      "hints": [
        "Each input can connect to one output",
        "Switch matrix is like permutation",
        "Loss accumulates through switches",
        "Some configurations impossible simultaneously"
      ]
    },
    {
      "id": "ex3",
      "title": "Quantum Memory Manager",
      "type": "coding",
      "difficulty": "intermediate",
      "points": 25,
      "description": "Manage quantum memory resources in a router.",
      "tasks": [
        "Track memory slot allocation",
        "Monitor qubit coherence times",
        "Implement store and retrieve operations",
        "Handle memory full conditions",
        "Calculate fidelity degradation over time"
      ],
      "expectedOutput": "Quantum memory management system",
      "hints": [
        "Track storage time per qubit",
        "Coherence degrades exponentially",
        "Prioritize near-expiration qubits",
        "Report memory utilization"
      ]
    },
    {
      "id": "ex4",
      "title": "Router Network Simulator",
      "type": "coding",
      "difficulty": "advanced",
      "points": 25,
      "description": "Simulate a network of quantum routers.",
      "tasks": [
        "Create multiple router instances",
        "Connect routers via quantum links",
        "Set up routing tables",
        "Trace packet paths through network",
        "Calculate end-to-end metrics"
      ],
      "expectedOutput": "Multi-router network simulator",
      "hints": [
        "Each router maintains local routing table",
        "Links have loss and latency",
        "End-to-end fidelity is product of hops",
        "Handle unreachable destinations"
      ]
    }
  ]
