{
  "exerciseId": "07-09-02-entanglement-routing-exercises",
  "title": "Exercises: Entanglement Routing",
  "exercises": [
    {
      "id": "ex1",
      "title": "Entanglement Swap Simulator",
      "type": "coding",
      "difficulty": "beginner",
      "points": 20,
      "description": "Simulate entanglement swapping operation.",
      "tasks": [
        "Model initial entangled pairs",
        "Implement Bell measurement simulation",
        "Calculate post-swap fidelity",
        "Track which nodes become entangled",
        "Generate swap result report"
      ],
      "expectedOutput": "Entanglement swapping simulator",
      "hints": [
        "Swapping connects distant nodes",
        "Fidelity is approximately product of inputs",
        "Bell measurement has 4 possible outcomes",
        "Classical communication announces result"
      ]
    },
    {
      "id": "ex2",
      "title": "Purification Protocol",
      "type": "coding",
      "difficulty": "intermediate",
      "points": 30,
      "description": "Implement entanglement purification protocol.",
      "tasks": [
        "Model BBPSSW-style purification",
        "Calculate success probability",
        "Compute resulting fidelity on success",
        "Track pairs consumed",
        "Determine rounds needed for target fidelity"
      ],
      "expectedOutput": "Purification protocol implementation",
      "hints": [
        "2 pairs combine to potentially make 1",
        "Success probability depends on input fidelity",
        "Output fidelity higher than inputs",
        "Multiple rounds may be needed"
      ]
    },
    {
      "id": "ex3",
      "title": "Multi-Path Router",
      "type": "coding",
      "difficulty": "intermediate",
      "points": 25,
      "description": "Route entanglement through multiple paths.",
      "tasks": [
        "Find multiple disjoint paths",
        "Establish entanglement on each path",
        "Aggregate results through purification",
        "Compare single vs multi-path fidelity",
        "Analyze resource costs"
      ],
      "expectedOutput": "Multi-path entanglement router",
      "hints": [
        "Disjoint paths share no intermediate nodes",
        "Each path produces one entangled pair",
        "Purification combines multiple pairs",
        "More paths = more resources but higher quality"
      ]
    },
    {
      "id": "ex4",
      "title": "Entanglement Network Optimizer",
      "type": "coding",
      "difficulty": "advanced",
      "points": 25,
      "description": "Optimize entanglement routing across a network.",
      "tasks": [
        "Model network topology with link fidelities",
        "Find optimal path maximizing end-to-end fidelity",
        "Balance path length vs link quality",
        "Schedule purification along path",
        "Calculate throughput and resource usage"
      ],
      "expectedOutput": "Network optimization for entanglement routing",
      "hints": [
        "Shortest path may not have best fidelity",
        "Higher-fidelity links may be worth extra hops",
        "Purification schedule affects throughput",
        "Consider link generation rates"
      ]
    }
  ]
}
