{
  "exerciseId": "07-09-04-resource-allocation-exercises",
  "title": "Exercises: Resource Allocation",
  "exercises": [
    {
      "id": "ex1",
      "title": "Quantum Memory Manager",
      "type": "coding",
      "difficulty": "beginner",
      "points": 20,
      "description": "Implement quantum memory allocation with coherence tracking.",
      "tasks": [
        "Model memory slots with coherence times",
        "Implement allocation with expiration tracking",
        "Auto-release expired allocations",
        "Report utilization and expiration warnings",
        "Handle allocation failures gracefully"
      ],
      "expectedOutput": "Memory manager with coherence awareness",
      "hints": [
        "Each slot has remaining coherence time",
        "Tick function advances time and expires slots",
        "Prioritize slots by remaining time",
        "Warn before expiration if possible"
      ]
    },
    {
      "id": "ex2",
      "title": "Multi-Policy Scheduler",
      "type": "coding",
      "difficulty": "intermediate",
      "points": 30,
      "description": "Implement and compare multiple scheduling policies.",
      "tasks": [
        "Implement FCFS, Priority, and EDF policies",
        "Generate random request streams",
        "Measure metrics (waiting time, deadline misses)",
        "Compare policies under different loads",
        "Recommend policy based on workload"
      ],
      "expectedOutput": "Scheduler with policy comparison",
      "hints": [
        "Use consistent workload for comparison",
        "Track deadline misses separately",
        "EDF typically best for deadlines",
        "FCFS simplest but may miss deadlines"
      ]
    },
    {
      "id": "ex3",
      "title": "Admission Controller",
      "type": "coding",
      "difficulty": "intermediate",
      "points": 25,
      "description": "Build admission control system with policies.",
      "tasks": [
        "Implement conservative and aggressive policies",
        "Set resource reservation thresholds",
        "Track admission/rejection statistics",
        "Analyze impact on completion rates",
        "Tune parameters for optimal performance"
      ],
      "expectedOutput": "Configurable admission controller",
      "hints": [
        "Conservative = only admit if resources exist now",
        "Aggressive = admit if expected by deadline",
        "Track both false rejections and failed completions",
        "Balance admission rate vs completion rate"
      ]
    },
    {
      "id": "ex4",
      "title": "Fair Allocation Algorithm",
      "type": "coding",
      "difficulty": "advanced",
      "points": 25,
      "description": "Implement fair resource allocation among competing flows.",
      "tasks": [
        "Implement proportional fairness allocation",
        "Implement max-min fairness",
        "Support weighted fairness",
        "Handle dynamic flow arrivals/departures",
        "Measure fairness metrics (Jain's index)"
      ],
      "expectedOutput": "Fair allocation with multiple algorithms",
      "hints": [
        "Proportional: maximize sum of log allocations",
        "Max-min: water-filling approach",
        "Jain's index measures equality (1 = perfect)",
        "Handle edge cases (new flows, departures)"
      ]
    }
  ]
}
