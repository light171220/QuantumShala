{
  "exerciseId": "07-10-05-industry-applications-exercises",
  "title": "Exercises: Industry Applications",
  "exercises": [
    {
      "id": "ex1",
      "title": "Use Case Catalog",
      "type": "coding",
      "difficulty": "beginner",
      "points": 20,
      "description": "Build a catalog of quantum network use cases by industry.",
      "tasks": [
        "Define industry sectors",
        "List use cases per sector",
        "Include value proposition for each",
        "Track deployment examples",
        "Search and filter capabilities"
      ],
      "expectedOutput": "Searchable use case catalog",
      "hints": [
        "Sectors: finance, government, healthcare, telecom, energy",
        "Multiple use cases per sector",
        "Include adoption readiness level",
        "Link to real-world examples where available"
      ]
    },
    {
      "id": "ex2",
      "title": "ROI Calculator",
      "type": "coding",
      "difficulty": "intermediate",
      "points": 30,
      "description": "Calculate ROI for quantum network deployment.",
      "tasks": [
        "Model cost components (equipment, operations)",
        "Model value drivers (risk reduction, compliance)",
        "Calculate payback period",
        "Compare scenarios (buy now vs wait)",
        "Generate ROI report"
      ],
      "expectedOutput": "Quantum network ROI calculator",
      "hints": [
        "Include CapEx and OpEx",
        "Quantify risk reduction value",
        "Consider technology cost decline over time",
        "Factor in regulatory compliance value"
      ]
    },
    {
      "id": "ex3",
      "title": "Sector Readiness Assessor",
      "type": "coding",
      "difficulty": "intermediate",
      "points": 25,
      "description": "Assess sector readiness for quantum network adoption.",
      "tasks": [
        "Define readiness criteria",
        "Score sectors against criteria",
        "Identify barriers and enablers",
        "Rank sectors by adoption likelihood",
        "Generate readiness report"
      ],
      "expectedOutput": "Sector readiness assessment tool",
      "hints": [
        "Criteria: budget, technical capability, regulatory pressure",
        "Different sectors have different drivers",
        "Early adopters pave way for others",
        "Identify what would accelerate adoption"
      ]
    },
    {
      "id": "ex4",
      "title": "Deployment Scenario Planner",
      "type": "coding",
      "difficulty": "advanced",
      "points": 25,
      "description": "Plan quantum network deployment for a specific industry.",
      "tasks": [
        "Input industry requirements",
        "Design network topology",
        "Select appropriate technologies",
        "Create phased deployment plan",
        "Estimate costs and timeline"
      ],
      "expectedOutput": "Industry-specific deployment plan",
      "hints": [
        "Different industries need different topologies",
        "Phase deployment by priority sites",
        "Match technology to requirements",
        "Include integration with existing infrastructure"
      ]
    }
  ]
}
