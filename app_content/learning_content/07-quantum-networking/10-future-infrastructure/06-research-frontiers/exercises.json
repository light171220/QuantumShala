{
  "exerciseId": "07-10-06-research-frontiers-exercises",
  "title": "Exercises: Research Frontiers",
  "exercises": [
    {
      "id": "ex1",
      "title": "Research Challenge Mapper",
      "type": "coding",
      "difficulty": "beginner",
      "points": 20,
      "description": "Map and categorize open research challenges.",
      "tasks": [
        "Define challenge categories",
        "Rate challenges by difficulty",
        "Track current state and breakthroughs needed",
        "Identify dependencies between challenges",
        "Generate research roadmap"
      ],
      "expectedOutput": "Research challenge mapping tool",
      "hints": [
        "Categories: memory, repeater, entanglement, protocols",
        "Difficulty: hard, very hard, unsolved",
        "Some challenges enable others",
        "Timeline based on current progress"
      ]
    },
    {
      "id": "ex2",
      "title": "Breakthrough Tracker",
      "type": "coding",
      "difficulty": "intermediate",
      "points": 30,
      "description": "Track and analyze research breakthroughs over time.",
      "tasks": [
        "Catalog recent breakthroughs",
        "Analyze progress trajectory",
        "Identify breakthrough patterns",
        "Predict next milestones",
        "Generate progress report"
      ],
      "expectedOutput": "Research breakthrough tracking and analysis",
      "hints": [
        "Include year, team, significance",
        "Look for acceleration patterns",
        "Connect breakthroughs to challenges solved",
        "Note what enabled each breakthrough"
      ]
    },
    {
      "id": "ex3",
      "title": "Technology Gap Analyzer",
      "type": "coding",
      "difficulty": "intermediate",
      "points": 25,
      "description": "Analyze gaps between current state and goals.",
      "tasks": [
        "Define target metrics (coherence, efficiency, etc.)",
        "Input current state of art",
        "Calculate gap to targets",
        "Estimate improvement rate needed",
        "Identify critical path"
      ],
      "expectedOutput": "Technology gap analysis with timeline",
      "hints": [
        "Metrics: coherence time, efficiency, rate, fidelity",
        "Historical progress indicates future rate",
        "Some gaps are orders of magnitude",
        "Critical path = longest gap sequence"
      ]
    },
    {
      "id": "ex4",
      "title": "Research Impact Estimator",
      "type": "coding",
      "difficulty": "advanced",
      "points": 25,
      "description": "Estimate impact of solving key research challenges.",
      "tasks": [
        "Model challenge dependencies",
        "Estimate impact of each challenge solution",
        "Calculate cumulative impact",
        "Identify highest-impact research areas",
        "Generate funding priority recommendations"
      ],
      "expectedOutput": "Research impact and priority analysis",
      "hints": [
        "Impact: applications enabled, capability unlocked",
        "Dependency graph shows cascade effects",
        "Some challenges unlock many applications",
        "Balance difficulty vs impact for priorities"
      ]
    }
  ]
}
