{
  "exerciseId": "07-10-04-standardization-exercises",
  "title": "Exercises: Standardization Efforts",
  "exercises": [
    {
      "id": "ex1",
      "title": "Standards Catalog",
      "type": "coding",
      "difficulty": "beginner",
      "points": 20,
      "description": "Build a catalog of quantum network standards.",
      "tasks": [
        "Define standard categories (security, interface, protocol)",
        "Store standards by organization",
        "Track publication status",
        "Search by category or organization",
        "Generate standards report"
      ],
      "expectedOutput": "Searchable standards catalog",
      "hints": [
        "Categories: security, interface, protocol, physical, management",
        "Status: published, in-progress, planned",
        "Key orgs: ETSI, ITU, ISO, IEEE, IETF",
        "Include scope description for each"
      ]
    },
    {
      "id": "ex2",
      "title": "Interoperability Gap Analyzer",
      "type": "coding",
      "difficulty": "intermediate",
      "points": 30,
      "description": "Analyze interoperability gaps by network layer.",
      "tasks": [
        "Define requirements by layer",
        "Track current standardization status",
        "Calculate readiness score per layer",
        "Identify critical gaps",
        "Generate roadmap for closing gaps"
      ],
      "expectedOutput": "Layer-by-layer gap analysis with roadmap",
      "hints": [
        "Layers: physical, link, network, application",
        "Readiness = standardized requirements / total",
        "Critical gaps block multi-vendor deployment",
        "Prioritize by deployment impact"
      ]
    },
    {
      "id": "ex3",
      "title": "Standards Compliance Checker",
      "type": "coding",
      "difficulty": "intermediate",
      "points": 25,
      "description": "Check product compliance against standards.",
      "tasks": [
        "Load standard requirements",
        "Input product capabilities",
        "Match capabilities to requirements",
        "Calculate compliance percentage",
        "Generate compliance report"
      ],
      "expectedOutput": "Standards compliance verification tool",
      "hints": [
        "Different standards for different product types",
        "Partial compliance possible",
        "Report missing capabilities",
        "Suggest path to full compliance"
      ]
    },
    {
      "id": "ex4",
      "title": "Standards Evolution Tracker",
      "type": "coding",
      "difficulty": "advanced",
      "points": 25,
      "description": "Track and predict standards evolution.",
      "tasks": [
        "Model standards lifecycle (draft→published→revised)",
        "Track dependencies between standards",
        "Predict publication timelines",
        "Identify emerging standards needs",
        "Generate evolution forecast"
      ],
      "expectedOutput": "Standards evolution tracking and forecasting",
      "hints": [
        "Standards take 2-5 years from start to publication",
        "Higher-layer standards depend on lower",
        "Technology advances create new needs",
        "International harmonization takes time"
      ]
    }
  ]
}
