{
  "exerciseId": "07-01-03-photon-transmission-exercises",
  "title": "Exercises: Photon Transmission",
  "exercises": [
    {
      "id": "ex1",
      "title": "Fiber Link Calculator",
      "type": "coding",
      "difficulty": "intermediate",
      "points": 25,
      "description": "Build a comprehensive fiber link budget calculator.",
      "tasks": [
        "Model fiber attenuation at different wavelengths",
        "Include connector and splice losses",
        "Calculate propagation delay",
        "Compute chromatic dispersion effects",
        "Generate complete link budget report"
      ],
      "expectedOutput": "Interactive fiber link budget tool",
      "hints": [
        "Attenuation: 0.2 dB/km at 1550 nm, 0.35 dB/km at 1310 nm",
        "Connector loss: ~0.3 dB each",
        "Splice loss: ~0.1 dB each",
        "Dispersion: ~17 ps/(nm·km) at 1550 nm"
      ]
    },
    {
      "id": "ex2",
      "title": "Polarization Encoding Simulator",
      "type": "coding",
      "difficulty": "intermediate",
      "points": 30,
      "description": "Implement a polarization-based qubit encoding system.",
      "tasks": [
        "Define basis states (HV, DA, RL)",
        "Implement state preparation",
        "Simulate measurement in different bases",
        "Calculate basis mismatch statistics",
        "Model polarization rotation effects"
      ],
      "expectedOutput": "Complete polarization encoding and measurement simulator",
      "hints": [
        "|H⟩ = [1,0], |V⟩ = [0,1]",
        "|D⟩ = (|H⟩+|V⟩)/√2, |A⟩ = (|H⟩-|V⟩)/√2",
        "Measurement projects onto basis",
        "Use Jones matrices for rotation"
      ]
    },
    {
      "id": "ex3",
      "title": "Single-Photon Source Analyzer",
      "type": "coding",
      "difficulty": "advanced",
      "points": 25,
      "description": "Compare single-photon source technologies.",
      "tasks": [
        "Model Poisson statistics for WCP",
        "Calculate g²(0) for different sources",
        "Simulate heralded source efficiency",
        "Analyze multi-photon probability impact",
        "Recommend source for given application"
      ],
      "expectedOutput": "Source comparison tool with g²(0) analysis",
      "hints": [
        "WCP: P(n) = μⁿe^(-μ)/n!",
        "g²(0) = ⟨n(n-1)⟩/⟨n⟩² for number states",
        "Decoy states use multiple μ values",
        "Consider rate vs purity trade-off"
      ]
    },
    {
      "id": "ex4",
      "title": "Detector Performance Simulator",
      "type": "coding",
      "difficulty": "intermediate",
      "points": 20,
      "description": "Simulate single-photon detector behavior.",
      "tasks": [
        "Model detection efficiency",
        "Implement dark count noise",
        "Calculate signal-to-noise ratio",
        "Simulate timing jitter effects",
        "Compare APD vs SNSPD performance"
      ],
      "expectedOutput": "Detector simulation with SNR analysis",
      "hints": [
        "APD: ~25% efficiency, ~1 kHz dark counts",
        "SNSPD: ~93% efficiency, ~10 Hz dark counts",
        "Include dead time effects",
        "SNR = signal_rate / √(signal + dark)"
      ]
    }
  ]
}
