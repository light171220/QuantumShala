      "id": "ex1",
      "title": "Security Comparison Tool",
      "type": "coding",
      "difficulty": "intermediate",
      "points": 25,
      "description": "Build a tool to compare classical and quantum security approaches.",
      "tasks": [
        "Model classical cryptography security levels",
        "Model QKD security properties",
        "Assess harvest-now-decrypt-later vulnerability",
        "Calculate security lifetime",
        "Generate recommendation based on requirements"
      ],
      "expectedOutput": "Security comparison and recommendation tool",
      "hints": [
        "Track security bits for classical methods",
        "QKD has infinite security bits (info-theoretic)",
        "Consider data sensitivity lifetime",
        "Factor in adversary capability assumptions"
      ]
    },
