{
  "exerciseId": "07-01-04-channel-capacity-exercises",
  "title": "Exercises: Quantum Channel Capacity",
  "exercises": [
    {
      "id": "ex1",
      "title": "Channel Capacity Calculator",
      "type": "coding",
      "difficulty": "advanced",
      "points": 30,
      "description": "Implement a quantum channel capacity calculator.",
      "tasks": [
        "Calculate von Neumann entropy",
        "Implement classical capacity for common channels",
        "Implement quantum capacity bounds",
        "Compare C, Q, P, and C_EA",
        "Plot capacities vs error parameter"
      ],
      "expectedOutput": "Multi-capacity calculator with visualization",
      "hints": [
        "S(ρ) = -Tr(ρ log ρ) using eigenvalues",
        "Depolarizing: C = 1 - H((1+η)/2)",
        "Use scipy.optimize for capacity optimization",
        "Verify C_EA ≥ C always"
      ]
    },
    {
      "id": "ex2",
      "title": "Holevo Bound Analyzer",
      "type": "coding",
      "difficulty": "intermediate",
      "points": 25,
      "description": "Analyze the Holevo bound for state ensembles.",
      "tasks": [
        "Calculate χ for orthogonal states",
        "Calculate χ for non-orthogonal states",
        "Show χ decreases with state overlap",
        "Implement optimal measurement bound",
        "Compare with superdense coding"
      ],
      "expectedOutput": "Holevo χ calculator for arbitrary ensembles",
      "hints": [
        "χ = S(ρ) - Σ pᵢ S(ρᵢ)",
        "For pure states, S(ρᵢ) = 0",
        "Orthogonal states achieve χ = H(p)",
        "Plot χ vs overlap angle"
      ]
    },
    {
      "id": "ex3",
      "title": "QKD Key Rate Simulator",
      "type": "coding",
      "difficulty": "intermediate",
      "points": 25,
      "description": "Build a comprehensive QKD key rate simulator.",
      "tasks": [
        "Model BB84 secret key rate formula",
        "Include fiber loss and detector effects",
        "Calculate QBER contributions",
        "Find maximum secure distance",
        "Compare different protocol variants"
      ],
      "expectedOutput": "QKD rate simulator with distance analysis",
      "hints": [
        "R = R_raw × (1 - 2h(e)) for symmetric case",
        "Include basis mismatch factor (0.5 for BB84)",
        "QBER threshold ~11%",
        "Compare BB84, Six-state, decoy-state"
      ]
    },
    {
      "id": "ex4",
      "title": "Superdense Coding Demo",
      "type": "coding",
      "difficulty": "intermediate",
      "points": 20,
      "description": "Implement the superdense coding protocol.",
      "tasks": [
        "Prepare shared Bell pair",
        "Encode 2 classical bits with Pauli operations",
        "Transmit one qubit",
        "Perform Bell measurement to decode",
        "Verify 2 bits per qubit transmission"
      ],
      "expectedOutput": "Working superdense coding protocol",
      "hints": [
        "Start with |Φ⁺⟩ = (|00⟩ + |11⟩)/√2",
        "Encodings: I→00, X→01, Z→10, XZ→11",
        "Bell measurement distinguishes all 4 Bell states",
        "Compare with Holevo bound"
      ]
    }
  ]
}
