{
  "exerciseId": "07-01-05-noise-loss-exercises",
  "title": "Exercises: Noise and Loss in Quantum Channels",
  "exercises": [
    {
      "id": "ex1",
      "title": "QBER Calculator",
      "type": "coding",
      "difficulty": "intermediate",
      "points": 25,
      "description": "Build a comprehensive QBER analysis tool.",
      "tasks": [
        "Model individual QBER components",
        "Calculate dark count contribution vs distance",
        "Find maximum secure distance",
        "Plot QBER vs distance",
        "Compare different detector technologies"
      ],
      "expectedOutput": "QBER analyzer with component breakdown",
      "hints": [
        "e_dark = 0.5 × dark/(signal + dark)",
        "Signal ∝ η × μ (transmission × mean photon)",
        "QBER threshold ~11% for BB84",
        "SNSPD: low dark counts; APD: higher dark counts"
      ]
    },
    {
      "id": "ex2",
      "title": "Decoherence Simulator",
      "type": "coding",
      "difficulty": "advanced",
      "points": 30,
      "description": "Simulate quantum decoherence with T1 and T2.",
      "tasks": [
        "Implement amplitude damping (T1)",
        "Implement dephasing (T2)",
        "Track density matrix evolution",
        "Calculate fidelity decay",
        "Compare different initial states"
      ],
      "expectedOutput": "Decoherence simulator with fidelity tracking",
      "hints": [
        "γ₁(t) = 1 - exp(-t/T1)",
        "γ₂(t) = 1 - exp(-t/T2)",
        "Off-diagonal: ρ₀₁ → ρ₀₁ × √(1-γ₁) × (1-γ₂)",
        "Fidelity F = ⟨ψ|ρ|ψ⟩"
      ]
    },
    {
      "id": "ex3",
      "title": "Decoy State Analyzer",
      "type": "coding",
      "difficulty": "intermediate",
      "points": 25,
      "description": "Implement decoy state protocol analysis.",
      "tasks": [
        "Model signal and decoy state yields",
        "Estimate single-photon contribution",
        "Calculate secure key rate with decoy",
        "Compare with no-decoy protocol",
        "Optimize decoy state intensities"
      ],
      "expectedOutput": "Decoy state key rate calculator",
      "hints": [
        "Use two or three intensity levels",
        "Y₁ estimation from yield differences",
        "e₁ estimation for single-photon QBER",
        "Key rate ~ Y₁ × (1 - h(e₁))"
      ]
    },
    {
      "id": "ex4",
      "title": "Error Correction Impact",
      "type": "coding",
      "difficulty": "intermediate",
      "points": 20,
      "description": "Analyze error correction and privacy amplification.",
      "tasks": [
        "Calculate error correction overhead",
        "Calculate privacy amplification cost",
        "Determine secret key fraction",
        "Compare code efficiencies",
        "Find crossover QBER for different codes"
      ],
      "expectedOutput": "Post-processing cost analyzer",
      "hints": [
        "EC cost = f × h(e) where f is efficiency factor",
        "PA cost = h(e) for symmetric channel",
        "Secret fraction = 1 - EC - PA",
        "Compare CASCADE (f=1.16) vs LDPC (f=1.05)"
      ]
    }
  ]
}
