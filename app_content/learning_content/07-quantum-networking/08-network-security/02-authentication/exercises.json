{
  "exerciseId": "07-08-02-authentication-exercises",
  "title": "Exercises: Authentication in Quantum Networks",
  "exercises": [
    {
      "id": "ex1",
      "title": "Authentication Scheme Comparator",
      "type": "coding",
      "difficulty": "beginner",
      "points": 20,
      "description": "Compare different authentication schemes for QKD.",
      "tasks": [
        "Define authentication schemes (Wegman-Carter, HMAC, etc.)",
        "Compare security levels",
        "Calculate key consumption rates",
        "Evaluate pros and cons for QKD use",
        "Generate recommendation"
      ],
      "expectedOutput": "Authentication scheme comparison tool",
      "hints": [
        "IT-secure schemes match QKD security",
        "Key consumption affects sustainability",
        "Consider both security and practicality",
        "Some schemes reuse keys, others consume"
      ]
    },
    {
      "id": "ex2",
      "title": "Authentication Key Manager",
      "type": "coding",
      "difficulty": "intermediate",
      "points": 30,
      "description": "Implement authentication key pool management.",
      "tasks": [
        "Track initial key pool",
        "Consume key for each authentication",
        "Replenish from QKD-generated keys",
        "Calculate sustainable message rate",
        "Warn when pool runs low"
      ],
      "expectedOutput": "Key pool management system",
      "hints": [
        "Start with pre-shared key",
        "Track consumption vs replenishment",
        "QKD must generate more than consumed",
        "Include safety margins"
      ]
    },
    {
      "id": "ex3",
      "title": "Man-in-the-Middle Simulator",
      "type": "coding",
      "difficulty": "intermediate",
      "points": 25,
      "description": "Simulate man-in-the-middle attack without authentication.",
      "tasks": [
        "Model unauthenticated QKD scenario",
        "Implement Eve's interception strategy",
        "Show how Eve establishes keys with both parties",
        "Demonstrate attack success",
        "Add authentication to prevent attack"
      ],
      "expectedOutput": "MITM attack demonstration and prevention",
      "hints": [
        "Eve runs QKD with Alice and Bob separately",
        "Without auth, neither knows Eve is present",
        "Authentication reveals impersonation",
        "Show before/after authentication"
      ]
    },
    {
      "id": "ex4",
      "title": "Bootstrapping Protocol Designer",
      "type": "coding",
      "difficulty": "advanced",
      "points": 25,
      "description": "Design a key bootstrapping protocol for QKD network.",
      "tasks": [
        "Define bootstrapping requirements",
        "Implement physical key distribution model",
        "Design computational to IT transition",
        "Calculate initial key requirements",
        "Generate deployment plan"
      ],
      "expectedOutput": "Bootstrapping protocol specification",
      "hints": [
        "Initial key must be distributed securely",
        "Hybrid approach: start computational",
        "Transition to IT-secure after first QKD",
        "Consider multi-party networks"
      ]
    }
  ]
}
