      "description": "Analyze security assumptions for different protocols.",
      "tasks": [
        "List assumptions for each protocol type",
        "Categorize by trust requirements",
        "Identify assumption violations",
        "Calculate impact of broken assumptions",
        "Generate assumption comparison"
      ],
      "expectedOutput": "Security assumption analysis tool",
      "hints": [
        "Different protocols have different assumptions",
        "DI has fewest assumptions",
        "Standard QKD assumes trusted devices",
