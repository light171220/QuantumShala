        "Input component protocol security",
        "Check composition rules",
        "Calculate combined security parameter",
        "Report composition validity"
      ],
      "expectedOutput": "Protocol composition security checker",
      "hints": [
        "UC security composes universally",
        "Security parameters may add",
        "Some compositions are invalid",
        "Consider sequential and parallel"
      ]
    },
    {
      "id": "ex3",
      "title": "DI-QKD Rate Calculator",
      "type": "coding",
      "difficulty": "advanced",
      "points": 30,
      "description": "Calculate key rates for device-independent QKD.",
      "tasks": [
