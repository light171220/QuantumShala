      "title": "Security Level Comparator",
      "type": "coding",
      "difficulty": "beginner",
      "points": 20,
      "description": "Compare different security levels and their guarantees.",
      "tasks": [
        "Define security levels (IT, computational, heuristic)",
        "List adversary capabilities for each",
        "Identify which cryptographic schemes fit each level",
        "Compare quantum vs classical approaches",
        "Generate comparison table"
      ],
      "expectedOutput": "Security level comparison tool",
      "hints": [
        "IT security: unbounded adversary",
        "Computational: polynomial-time adversary",
        "QKD is IT-secure",
        "RSA is computationally secure"
      ]
    },
