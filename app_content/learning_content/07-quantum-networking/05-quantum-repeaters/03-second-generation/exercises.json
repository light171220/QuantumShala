  "title": "Exercises: Second-Generation Repeaters",
  "exercises": [
    {
      "id": "ex1",
      "title": "Encoded Repeater Simulator",
      "type": "coding",
      "difficulty": "advanced",
      "points": 35,
      "description": "Implement second-generation repeater with QEC codes.",
      "tasks": [
        "Implement logical Bell pair encoding (Steane code)",
        "Calculate logical error rates from physical errors",
        "Simulate deterministic logical BSM",
        "Track fidelity through encoded swapping",
        "Compare with first-generation at same distance"
      ],
      "expectedOutput": "Working encoded repeater simulation",
      "hints": [
        "[[7,1,3]] Steane code corrects 1 error",
        "Logical error rate scales as p^2 for d=3",
        "Deterministic BSM: no 50% penalty",
        "Trade physical qubit count for reliability"
      ]
    },
    {
      "id": "ex2",
      "title": "Loss-Tolerant Encoding",
      "type": "coding",
      "difficulty": "advanced",
      "points": 30,
      "description": "Model loss-tolerant quantum codes for fiber transmission.",
      "tasks": [
        "Implement quantum parity code",
        "Calculate survival probability vs loss rate",
        "Simulate partial photon arrival scenarios",
        "Determine break-even loss rate",
        "Optimize code parameters for given fiber length"
      ],
      "expectedOutput": "Loss-tolerant code simulation",
      "hints": [
        "Loss → erasure errors (known locations)",
        "Erasure easier to correct than unknown errors",
        "Need enough photons to decode",
        "Trade redundancy for loss tolerance"
      ]
    },
    {
      "id": "ex3",
      "title": "One-Way vs Two-Way Comparison",
      "type": "coding",
      "difficulty": "intermediate",
      "points": 20,
      "description": "Compare one-way and two-way second-gen approaches.",
      "tasks": [
        "Model two-way encoded repeater",
        "Model one-way cluster-based repeater",
        "Calculate rate and fidelity for both",
        "Analyze resource requirements",
        "Identify advantages of each approach"
      ],
      "expectedOutput": "Comparative analysis tool",
      "hints": [
        "Two-way: encoded Bell pairs + gates",
        "One-way: cluster states + measurements",
        "One-way may need larger clusters",
        "Two-way needs bidirectional transmission"
      ]
    },
    {
      "id": "ex4",
      "title": "Generation Crossover Analysis",
      "type": "coding",
      "difficulty": "intermediate",
      "points": 15,
      "description": "Find when second-gen outperforms first-gen.",
      "tasks": [
        "Model both generations across parameter ranges",
        "Find crossover distance for rate",
        "Find crossover for fidelity requirements",
        "Analyze technology requirements for crossover",
        "Generate decision guidelines"
      ],
      "expectedOutput": "Generation comparison and selection tool",
      "hints": [
        "2nd gen wins at longer distances",
        "1st gen simpler for short distances",
        "Physical error rate affects crossover",
        "Consider implementation complexity"
      ]
