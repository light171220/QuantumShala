  "exercises": [
    {
      "id": "ex1",
      "title": "Toeplitz Hash Implementation",
      "type": "coding",
      "difficulty": "intermediate",
      "points": 30,
      "description": "Implement Toeplitz matrix universal hashing.",
      "tasks": [
        "Generate Toeplitz matrix from seed",
        "Implement matrix-vector multiplication mod 2",
        "Verify 2-universality property",
        "Optimize for large inputs",
        "Compare with naive random matrix"
      ],
      "expectedOutput": "Efficient Toeplitz hash implementation",
      "hints": [
        "Toeplitz: row[i] = seed[n-1-j+i : n-1-j+i+l]",
        "Need only n+l-1 random bits for seed",
        "Test: Pr[h(x) = h(y)] ≈ 2^(-l) for random h",
        "FFT can speed up multiplication"
      ]
    },
    {
      "id": "ex2",
      "title": "Key Length Calculator",
      "type": "coding",
      "difficulty": "intermediate",
      "points": 25,
      "description": "Calculate secure final key length from QKD parameters.",
      "tasks": [
        "Implement entropy calculations",
        "Model Eve's information from QBER",
        "Include EC leakage",
        "Add security parameter margin",
        "Plot key length vs QBER"
      ],
      "expectedOutput": "Secure key length calculation tool",
      "hints": [
        "Eve info ≈ n × h(QBER)",
        "EC leakage = f × n × h(QBER)",
        "Security: subtract 2log(1/ε)",
        "Key length = 0 when QBER ≈ 11%"
      ]
    },
    {
      "id": "ex3",
      "title": "Complete Post-Processing Pipeline",
      "type": "coding",
      "difficulty": "advanced",
      "points": 30,
      "description": "Build full QKD post-processing: EC + PA.",
      "tasks": [
        "Chain error correction and privacy amplification",
        "Handle edge cases (EC failure, no secure bits)",
        "Verify final keys match",
        "Generate detailed statistics",
        "Test with various QBER levels"
      ],
      "expectedOutput": "End-to-end post-processing pipeline",
      "hints": [
        "EC must succeed before PA",
        "PA fails if QBER too high",
        "Final keys should be identical",
        "Track all leakage sources"
      ]
    },
    {
      "id": "ex4",
      "title": "Security Analysis Tool",
      "type": "coding",
      "difficulty": "advanced",
      "points": 15,
      "description": "Analyze composable security of privacy amplification.",
      "tasks": [
        "Calculate trace distance to ideal",
        "Verify Leftover Hash Lemma conditions",
        "Check composable security requirements",
        "Analyze security vs key length tradeoff",
        "Generate security certification"
      ],
      "expectedOutput": "PA security analysis tool",
      "hints": [
        "Trace distance ≤ 2^(-(k-l)/2)",
        "LHL requires l ≤ k - 2log(1/ε)",
        "Composable: key independent of Eve",
        "Smaller ε → shorter key"
      ]
