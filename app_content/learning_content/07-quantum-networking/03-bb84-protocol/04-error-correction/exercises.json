{
  "exerciseId": "07-03-04-error-correction-exercises",
  "title": "Exercises: Error Correction",
  "exercises": [
    {
      "id": "ex1",
      "title": "CASCADE Protocol Implementation",
      "type": "coding",
      "difficulty": "advanced",
      "points": 35,
      "description": "Implement the CASCADE error correction protocol.",
      "tasks": [
        "Implement parity computation for blocks",
        "Implement binary search within blocks",
        "Add multiple passes with permutation",
        "Implement cascade effect checking",
        "Track and report information leakage"
      ],
      "expectedOutput": "Complete CASCADE implementation with statistics",
      "hints": [
        "Initial block size ≈ 0.73/QBER",
        "Binary search needs log₂(block_size) parities",
        "Cascade: correcting bit may reveal error elsewhere",
        "Track total parities exchanged for leakage"
      ]
    },
    {
      "id": "ex2",
      "title": "LDPC Syndrome Decoder",
      "type": "coding",
      "difficulty": "advanced",
      "points": 30,
      "description": "Build a simple LDPC syndrome-based reconciliation.",
      "tasks": [
        "Generate sparse parity check matrix",
        "Compute syndromes for Alice's key",
        "Implement bit-flipping decoder",
        "Compare efficiency with CASCADE",
        "Analyze failure modes"
      ],
      "expectedOutput": "LDPC reconciliation implementation",
      "hints": [
        "LDPC matrix is sparse (few 1s per column)",
        "Syndrome s = H × k mod 2",
        "Bit-flipping: flip bits in most unsatisfied checks",
        "May not always converge"
      ]
    },
    {
      "id": "ex3",
      "title": "Leakage Analyzer",
      "type": "coding",
      "difficulty": "intermediate",
      "points": 20,
      "description": "Analyze information leakage in error correction.",
      "tasks": [
        "Calculate Shannon limit for given QBER",
        "Compute practical leakage for different f values",
        "Determine remaining secret bits",
        "Plot leakage vs QBER",
        "Compare CASCADE and LDPC"
      ],
      "expectedOutput": "Error correction leakage analysis tool",
      "hints": [
        "Shannon: n × h(e) bits minimum",
        "Practical: f × Shannon limit",
        "Secret ≈ n × (1 - h(e) - f×h(e))",
        "Higher QBER → more leakage"
      ]
    },
    {
      "id": "ex4",
      "title": "Verification Protocol",
      "type": "coding",
      "difficulty": "beginner",
      "points": 15,
      "description": "Implement key verification after error correction.",
      "tasks": [
        "Implement hash-based verification",
        "Calculate collision probability",
        "Determine optimal hash length",
        "Handle verification failure",
        "Report verification statistics"
      ],
      "expectedOutput": "Verification protocol implementation",
      "hints": [
        "Hash: simple checksum or crypto hash",
        "Collision prob ≈ 2^(-hash_bits)",
        "Longer hash → more leakage but safer",
        "Failure → discard key, try again"
      ]
    }
  ]
}
