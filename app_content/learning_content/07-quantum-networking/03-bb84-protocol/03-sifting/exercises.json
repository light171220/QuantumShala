      "id": "ex1",
      "title": "Sifting Protocol Simulator",
      "type": "coding",
      "difficulty": "beginner",
      "points": 25,
      "description": "Implement complete sifting protocol simulation.",
      "tasks": [
        "Generate random bits and bases for Alice",
        "Generate random measurement bases for Bob",
        "Simulate Bob's measurement results",
        "Implement basis comparison and sifting",
        "Calculate and verify sifting efficiency"
      ],
      "expectedOutput": "Complete sifting simulation",
      "hints": [
        "Alice: random bits, random bases",
        "Bob: random bases, results depend on basis match",
        "Matching basis → copy bit, mismatched → random",
        "Efficiency should be ~50%"
      ]
    },
    {
      "id": "ex2",
      "title": "QBER Estimator with Confidence Intervals",
      "type": "coding",
      "difficulty": "intermediate",
      "points": 30,
      "description": "Build QBER estimation with statistical analysis.",
      "tasks": [
        "Implement QBER calculation from sample",
        "Calculate confidence intervals (Clopper-Pearson or Wilson)",
        "Determine optimal sample size for target accuracy",
        "Analyze finite-size effects",
        "Make security decision based on CI"
      ],
      "expectedOutput": "QBER estimator with statistical guarantees",
      "hints": [
        "QBER = errors / sample_size",
        "Use binomial distribution for CI",
        "Larger sample → tighter CI",
        "Decision based on upper bound of CI"
      ]
    },
    {
      "id": "ex3",
      "title": "Efficiency Optimizer",
      "type": "coding",
      "difficulty": "intermediate",
      "points": 25,
      "description": "Analyze and optimize sifting efficiency.",
      "tasks": [
        "Calculate theoretical efficiency for different protocols",
        "Include detection probability effects",
        "Model distance-dependent efficiency",
        "Compare protocols at various distances",
        "Recommend optimal protocol for scenario"
      ],
      "expectedOutput": "Sifting efficiency analysis tool",
      "hints": [
        "BB84: 50%, B92: 25%, Six-state: 33%",
        "Detection prob affects actual efficiency",
        "Efficiency drops with distance (loss)",
        "Consider overall key rate, not just sifting"
      ]
    },
    {
      "id": "ex4",
      "title": "Complete Sifting Pipeline",
      "type": "coding",
      "difficulty": "advanced",
