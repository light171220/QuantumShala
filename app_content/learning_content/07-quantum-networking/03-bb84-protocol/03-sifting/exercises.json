      "description": "Build end-to-end sifting and parameter estimation pipeline.",
      "tasks": [
        "Combine sifting and parameter estimation",
        "Implement security decision logic",
        "Handle edge cases (no matches, all errors)",
        "Generate detailed pipeline report",
        "Visualize sifting process"
      ],
      "expectedOutput": "Production-ready sifting pipeline",
