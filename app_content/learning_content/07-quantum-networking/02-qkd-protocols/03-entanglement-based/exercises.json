{
  "exerciseId": "07-02-03-entanglement-based-exercises",
  "title": "Exercises: Entanglement-Based Protocols",
  "exercises": [
    {
      "id": "ex1",
      "title": "E91 Protocol Simulator",
      "type": "coding",
      "difficulty": "advanced",
      "points": 30,
      "description": "Build a complete E91 protocol simulator with Bell test verification.",
      "tasks": [
        "Implement entangled pair generation with configurable fidelity",
        "Create measurement in arbitrary basis angles",
        "Implement CHSH Bell test calculation",
        "Separate key generation and test rounds",
        "Visualize Bell violation vs noise level"
      ],
      "expectedOutput": "E91 simulator with Bell inequality testing",
      "hints": [
        "Use correlation function E(θ₁,θ₂) = -cos(θ₁-θ₂)",
        "CHSH angles: 0°, 45°, 22.5°, 67.5°",
        "Track four correlators for S calculation",
        "White noise reduces S toward 0"
      ]
    },
    {
      "id": "ex2",
      "title": "Entanglement Source Characterizer",
      "type": "coding",
      "difficulty": "intermediate",
      "points": 25,
      "description": "Create a tool to characterize entanglement source quality.",
      "tasks": [
        "Measure Bell state fidelity",
        "Estimate entanglement visibility",
        "Detect mixed-state contributions",
        "Calculate achievable key rate",
        "Generate source quality report"
      ],
      "expectedOutput": "Entanglement source characterization tool",
      "hints": [
        "Fidelity F = ⟨Φ+|ρ|Φ+⟩",
        "Visibility from fringe contrast",
        "White noise: ρ = F|Φ+⟩⟨Φ+| + (1-F)I/4",
        "Key rate depends on S value"
      ]
    },
    {
      "id": "ex3",
      "title": "DI-QKD Proof-of-Concept",
      "type": "coding",
      "difficulty": "advanced",
      "points": 30,
      "description": "Implement device-independent QKD with loophole analysis.",
      "tasks": [
        "Create black-box device abstraction",
        "Implement randomness expansion from Bell violation",
        "Calculate min-entropy from observed statistics",
        "Identify detection loophole requirements",
        "Estimate practical key rates"
      ],
      "expectedOutput": "DI-QKD framework with security analysis",
      "hints": [
        "Treat devices as input→output boxes",
        "Min-entropy: H_min ≥ 1 - log(1 + √(2-S²/2))",
        "Detection efficiency > 82.8% for loophole-free",
        "Key rate from Devetak-Winter formula"
      ]
    },
    {
      "id": "ex4",
      "title": "Protocol Comparison Dashboard",
      "type": "coding",
      "difficulty": "intermediate",
      "points": 15,
      "description": "Build a comparison tool for entanglement vs prepare-measure protocols.",
      "tasks": [
        "Compare key rates at various distances",
        "Model quadratic vs linear loss",
        "Analyze security assumptions",
        "Generate protocol recommendation",
        "Visualize tradeoffs interactively"
      ],
      "expectedOutput": "Interactive protocol comparison dashboard",
      "hints": [
        "P&M: detected ∝ 10^(-αL/10)",
        "Entanglement: detected ∝ 10^(-αL/5)",
        "Consider source complexity",
        "Trust model differences crucial"
      ]
    }
  ]
