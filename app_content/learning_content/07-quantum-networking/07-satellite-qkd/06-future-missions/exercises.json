{
  "exerciseId": "07-07-06-future-missions-exercises",
  "title": "Exercises: Future Satellite Missions",
  "exercises": [
    {
      "id": "ex1",
      "title": "Mission Comparison Tool",
      "type": "coding",
      "difficulty": "beginner",
      "points": 20,
      "description": "Build a tool to compare future satellite QKD missions.",
      "tasks": [
        "Create database of planned missions",
        "Compare by country, timeline, objectives",
        "Categorize by technology level",
        "Generate comparison tables",
        "Identify technology leaders"
      ],
      "expectedOutput": "Mission comparison and analysis tool",
      "hints": [
        "Include launch year, orbit, objectives",
        "Group by country/region",
        "Consider both government and commercial",
        "Track mission status updates"
      ]
    },
    {
      "id": "ex2",
      "title": "Technology Gap Analyzer",
      "type": "coding",
      "difficulty": "intermediate",
      "points": 30,
      "description": "Analyze technology gaps between current and future systems.",
      "tasks": [
        "Define current Micius-class capabilities",
        "Define next-gen target capabilities",
        "Calculate improvement factors needed",
        "Identify hardest technology gaps",
        "Propose development priorities"
      ],
      "expectedOutput": "Technology gap and priority analysis",
      "hints": [
        "Key rate: 1 kbps → 10+ kbps",
        "Daytime operation is major gap",
        "Miniaturization for cost reduction",
        "Some gaps are physics-limited"
      ]
    },
    {
      "id": "ex3",
      "title": "Constellation Cost Estimator",
      "type": "coding",
      "difficulty": "intermediate",
      "points": 25,
      "description": "Estimate costs for various constellation configurations.",
      "tasks": [
        "Model satellite development costs",
        "Include launch costs by orbit",
        "Add ground segment costs",
        "Scale with constellation size",
        "Compare cost-effectiveness"
      ],
      "expectedOutput": "Constellation cost analysis tool",
      "hints": [
        "Larger satellites cost more",
        "Launch costs vary with mass and orbit",
        "Ground stations have fixed and variable costs",
        "Mass production reduces per-unit costs"
      ]
    },
    {
      "id": "ex4",
      "title": "Timeline Projection Tool",
      "type": "coding",
      "difficulty": "advanced",
      "points": 25,
      "description": "Project satellite QKD development timeline.",
      "tasks": [
        "Input known mission schedules",
        "Model technology development curves",
        "Project capability availability dates",
        "Include uncertainty ranges",
        "Generate timeline visualization"
      ],
      "expectedOutput": "Development timeline projection",
      "hints": [
        "Some missions are delayed",
        "Technology follows learning curves",
        "Political/funding affects schedules",
        "Consider optimistic and conservative cases"
      ]
    }
  ]
}
