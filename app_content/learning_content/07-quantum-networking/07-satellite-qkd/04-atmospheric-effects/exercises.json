      "id": "ex1",
      "title": "Atmospheric Transmission Calculator",
      "type": "coding",
      "difficulty": "intermediate",
      "points": 25,
      "description": "Model atmospheric transmission at different wavelengths and angles.",
      "tasks": [
        "Implement Beer-Lambert absorption model",
        "Calculate transmission vs zenith angle",
        "Compare different wavelength windows",
        "Include altitude correction",
        "Generate transmission curves"
      ],
      "expectedOutput": "Atmospheric transmission calculator",
      "hints": [
        "Airmass ≈ sec(zenith_angle)",
        "Transmission = exp(-tau × airmass)",
        "Different wavelengths have different tau",
        "Higher altitude = less atmosphere above"
      ]
    },
