      "points": 30,
      "description": "Simulate turbulence effects on satellite optical links.",
      "tasks": [
        "Model Fried parameter variations",
        "Calculate Strehl ratio degradation",
        "Simulate scintillation statistics",
        "Estimate fiber coupling efficiency",
        "Compare different turbulence conditions"
      ],
      "expectedOutput": "Turbulence impact simulation",
      "hints": [
        "Strehl ≈ exp(-(D/r0)^5/3)",
        "Scintillation variance depends on Cn²",
        "Fiber coupling drops with turbulence",
        "Consider both weak and strong turbulence"
      ]
    },
