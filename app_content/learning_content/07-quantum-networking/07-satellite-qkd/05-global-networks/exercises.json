  "title": "Exercises: Global Satellite Networks",
  "exercises": [
    {
      "id": "ex1",
      "title": "Constellation Coverage Calculator",
      "type": "coding",
      "difficulty": "intermediate",
      "points": 25,
      "description": "Calculate coverage metrics for satellite constellations.",
      "tasks": [
        "Model satellite orbital parameters",
        "Calculate ground track patterns",
        "Determine coverage circles",
        "Estimate revisit times",
        "Compare different constellation sizes"
      ],
      "expectedOutput": "Constellation coverage analysis tool",
      "hints": [
        "Coverage depends on altitude and elevation angle",
        "Revisit = period / sats_per_plane",
        "More planes = better longitude coverage",
        "Inclination affects latitude coverage"
      ]
    },
    {
      "id": "ex2",
      "title": "Inter-Satellite Link Designer",
      "type": "coding",
      "difficulty": "advanced",
      "points": 30,
      "description": "Design inter-satellite quantum links for constellation.",
      "tasks": [
        "Calculate ISL distances in constellation",
        "Determine link budget (geometric loss only)",
        "Design telescope sizes for target loss",
        "Plan ISL topology (ring, mesh)",
        "Estimate constellation-wide key capacity"
      ],
      "expectedOutput": "ISL design and capacity tool",
      "hints": [
        "ISL distance varies with constellation geometry",
        "No atmosphere = only geometric loss",
        "Larger telescopes = lower loss",
        "Mesh topology provides redundancy"
      ]
    },
    {
      "id": "ex3",
      "title": "Hybrid Network Optimizer",
      "type": "coding",
      "difficulty": "intermediate",
      "points": 25,
      "description": "Optimize routing between fiber and satellite segments.",
      "tasks": [
        "Input endpoint locations",
        "Calculate fiber path feasibility",
        "Determine satellite visibility",
        "Select optimal path (fiber vs satellite)",
        "Generate routing recommendation"
      ],
      "expectedOutput": "Hybrid network routing tool",
      "hints": [
        "Short distance: fiber preferred",
        "Long distance: satellite required",
        "Consider availability (weather)",
        "May need multi-hop solutions"
      ]
    },
    {
      "id": "ex4",
      "title": "Global Coverage Visualizer",
      "type": "coding",
      "difficulty": "beginner",
      "points": 20,
      "description": "Visualize global QKD network coverage.",
      "tasks": [
        "Input ground station locations",
        "Calculate satellite visibility windows",
        "Determine coverage gaps",
        "Identify regions needing more stations",
        "Generate coverage map data"
      ],
      "expectedOutput": "Coverage gap analysis tool",
      "hints": [
        "Latitude affects LEO visibility",
        "Multiple stations provide redundancy",
        "Weather affects actual availability",
        "Consider both hemispheres"
      ]
    }
