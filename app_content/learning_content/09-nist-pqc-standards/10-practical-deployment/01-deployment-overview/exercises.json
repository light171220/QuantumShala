{
  "exerciseId": "10-01-deployment-overview-exercises",
  "title": "Exercises: Deployment Overview",
  "exercises": [
    {
      "id": "ex1",
      "title": "Readiness Assessment Tool",
      "type": "coding",
      "difficulty": "intermediate",
      "points": 30,
      "description": "Build a deployment readiness assessment tool.",
      "tasks": [
        "Define prerequisite categories and items",
        "Implement readiness scoring",
        "Generate visual checklist",
        "Calculate go/no-go recommendation",
        "Track progress over time"
      ],
      "expectedOutput": "Readiness assessment tool with scoring and recommendations",
      "hints": [
        "Include infrastructure, application, and operations categories",
        "Weight critical prerequisites higher",
        "Provide clear guidance on what to verify",
        "Support partial readiness states"
      ]
    },
    {
      "id": "ex2",
      "title": "Risk Registry Manager",
      "type": "coding",
      "difficulty": "intermediate",
      "points": 25,
      "description": "Create a deployment risk registry management tool.",
      "tasks": [
        "Define risk attributes (likelihood, impact, mitigation)",
        "Calculate risk scores",
        "Prioritize risks for attention",
        "Track mitigation status",
        "Generate risk report"
      ],
      "expectedOutput": "Risk registry with scoring and reporting",
      "hints": [
        "Include common PQC deployment risks",
        "Allow custom risk addition",
        "Link mitigations to risk reduction",
        "Highlight unaddressed high risks"
      ]
    },
    {
      "id": "ex3",
      "title": "Deployment Strategy Selector",
      "type": "coding",
      "difficulty": "beginner",
      "points": 25,
      "description": "Build a tool to recommend deployment strategies.",
      "tasks": [
        "Define strategy characteristics",
        "Input organization parameters",
        "Match parameters to strategies",
        "Generate recommendation with rationale",
        "Compare pros/cons of top options"
      ],
      "expectedOutput": "Strategy recommendation tool",
      "hints": [
        "Consider environment size and complexity",
        "Factor in risk tolerance",
        "Account for team experience",
        "Include regulatory requirements"
      ]
    },
    {
      "id": "ex4",
      "title": "Success Metrics Dashboard",
      "type": "analysis",
      "difficulty": "beginner",
      "points": 20,
      "description": "Design a success metrics dashboard for PQC deployment.",
      "tasks": [
        "Define technical, operational, and business metrics",
        "Set thresholds for success/warning/failure",
        "Design dashboard layout",
        "Specify data sources",
        "Create alerting rules"
      ],
      "expectedOutput": "Success metrics dashboard design",
      "hints": [
        "Include handshake success rate and latency",
        "Track error rates over time",
        "Compare against baseline",
        "Enable drill-down for investigation"
      ]
    }
  ]
}
