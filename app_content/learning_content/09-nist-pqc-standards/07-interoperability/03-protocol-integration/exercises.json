{
  "exerciseId": "07-03-protocol-integration-exercises",
  "title": "Exercises: Protocol Integration",
  "exercises": [
    {
      "id": "ex1",
      "title": "Algorithm Negotiator",
      "type": "coding",
      "difficulty": "intermediate",
      "points": 30,
      "description": "Build a complete algorithm negotiation system.",
      "tasks": [
        "Define supported algorithm registry",
        "Implement client preference encoding",
        "Implement server selection logic",
        "Handle no-common-algorithm case",
        "Log negotiation decisions"
      ],
      "expectedOutput": "Working algorithm negotiation with logging",
      "hints": [
        "Server preference typically wins in TLS",
        "Include algorithm versions in identifiers",
        "Return detailed error on negotiation failure",
        "Support configuration of fallback behavior"
      ]
    },
    {
      "id": "ex2",
      "title": "Multi-Certificate Server",
      "type": "coding",
      "difficulty": "advanced",
      "points": 30,
      "description": "Implement certificate selection logic for servers with multiple certificates.",
      "tasks": [
        "Store multiple certificates per domain",
        "Select based on client signature algorithms",
        "Handle certificate chain building",
        "Implement priority-based selection",
        "Add fallback for unsupported algorithms"
      ],
      "expectedOutput": "Multi-certificate server implementation",
      "hints": [
        "Parse client signature_algorithms extension",
        "Match certificate signature to client support",
        "Consider issuer algorithm compatibility",
        "Support hybrid and non-hybrid certificates"
      ]
    },
    {
      "id": "ex3",
      "title": "Backward Compatibility Analyzer",
      "type": "analysis",
      "difficulty": "intermediate",
      "points": 20,
      "description": "Analyze backward compatibility requirements for PQC deployment.",
      "tasks": [
        "Document client compatibility matrix",
        "Identify potential negotiation failures",
        "Recommend fallback strategies",
        "Create compatibility testing plan",
        "Design graceful degradation"
      ],
      "expectedOutput": "Compatibility analysis document",
      "hints": [
        "Consider browser and OS versions",
        "Document library support status",
        "Plan for legacy system coexistence",
        "Include timeline recommendations"
      ]
    },
    {
      "id": "ex4",
      "title": "Message Size Impact Tool",
      "type": "coding",
      "difficulty": "beginner",
      "points": 20,
      "description": "Calculate the impact of PQC on protocol message sizes.",
      "tasks": [
        "Model TLS handshake messages",
        "Calculate size with different algorithms",
        "Identify MTU fragmentation points",
        "Recommend protocol adjustments",
        "Generate comparison report"
      ],
      "expectedOutput": "Message size analysis tool",
      "hints": [
        "TLS ClientHello includes supported_groups",
        "Server sends certificate chain",
        "Key share contains public key",
        "Consider round-trip implications"
      ]
    }
  ]
}
