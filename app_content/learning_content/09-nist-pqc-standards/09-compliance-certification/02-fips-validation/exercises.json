{
  "exerciseId": "09-02-fips-validation-exercises",
  "title": "Exercises: FIPS 140-3 Validation",
  "exercises": [
    {
      "id": "ex1",
      "title": "CMVP Timeline Planner",
      "type": "coding",
      "difficulty": "intermediate",
      "points": 30,
      "description": "Build a CMVP validation timeline planning and tracking tool.",
      "tasks": [
        "Define validation phases with typical durations",
        "Allow customization of start dates",
        "Calculate estimated completion dates",
        "Track actual progress against plan",
        "Generate Gantt-style visualization"
      ],
      "expectedOutput": "Validation timeline planner with progress tracking",
      "hints": [
        "Include CAVP and CMVP phases",
        "Add buffer for CMVP queue delays",
        "Track dependencies between phases",
        "Allow phase duration adjustment"
      ]
    },
    {
      "id": "ex2",
      "title": "Security Policy Generator",
      "type": "coding",
      "difficulty": "intermediate",
      "points": 25,
      "description": "Create a template-based security policy document generator.",
      "tasks": [
        "Define security policy structure",
        "Input module and vendor information",
        "Add algorithms with CAVP references",
        "Document cryptographic services",
        "Generate formatted policy document"
      ],
      "expectedOutput": "Security policy generator for FIPS modules",
      "hints": [
        "Follow FIPS 140-3 IG structure",
        "Include all required sections",
        "Reference CAVP certificate numbers",
        "Document operating environments"
      ]
    },
    {
      "id": "ex3",
      "title": "CAVP Test Tracker",
      "type": "coding",
      "difficulty": "beginner",
      "points": 25,
      "description": "Build a tracker for CAVP algorithm test status.",
      "tasks": [
        "List required tests per algorithm",
        "Track submission and result status",
        "Store CAVP certificate numbers",
        "Check readiness for CMVP",
        "Generate status report"
      ],
      "expectedOutput": "CAVP test tracking system",
      "hints": [
        "ML-KEM needs keygen, encaps, decaps tests",
        "ML-DSA needs keygen, sign, verify tests",
        "All tests must pass before CMVP",
        "Track certificate expiration"
      ]
    },
    {
      "id": "ex4",
      "title": "Validation Cost Estimator",
      "type": "analysis",
      "difficulty": "intermediate",
      "points": 20,
      "description": "Create a cost estimation tool for FIPS validation.",
      "tasks": [
        "Define cost categories (lab, NIST, internal)",
        "Estimate costs by security level",
        "Account for algorithm count",
        "Include re-validation costs",
        "Generate budget proposal"
      ],
      "expectedOutput": "Validation cost estimation tool",
      "hints": [
        "Lab costs vary by security level",
        "More algorithms = more CAVP costs",
        "Factor in internal labor",
        "Include contingency for delays"
      ]
    }
  ]
}
