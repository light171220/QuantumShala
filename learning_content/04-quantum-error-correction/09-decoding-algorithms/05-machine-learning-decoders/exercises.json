{
  "exerciseId": "04-09-05-ml-decoders-exercises",
  "title": "Exercises: Machine Learning Decoders",
  "exercises": [
    {
      "id": "ex1",
      "title": "Training Data Generator",
      "type": "coding",
      "difficulty": "intermediate",
      "points": 25,
      "description": "Generate training data for ML decoders.",
      "tasks": [
        "Sample random errors from depolarizing model",
        "Compute syndromes for each error",
        "Compute optimal corrections (using MWPM)",
        "Balance dataset across syndrome patterns",
        "Save as training/validation/test splits"
      ],
      "expectedOutput": "Training dataset generator",
      "hints": [
        "Use pymatching for optimal corrections",
        "Include rare syndromes by oversampling",
        "Typical split: 80/10/10",
        "Save in efficient format (numpy, HDF5)"
      ]
    },
    {
      "id": "ex2",
      "title": "Simple NN Decoder",
      "type": "coding",
      "difficulty": "intermediate",
      "points": 25,
      "description": "Implement and train a feedforward neural network decoder.",
      "tasks": [
        "Build 3-layer feedforward network in PyTorch/TensorFlow",
        "Train on generated syndrome-correction pairs",
        "Evaluate accuracy on test set",
        "Compare to MWPM on same test data",
        "Plot learning curves"
      ],
      "expectedOutput": "Trained feedforward decoder",
      "hints": [
        "Input: syndrome vector, Output: per-qubit correction",
        "Use BCELoss for binary outputs",
        "Try different hidden layer sizes",
        "Watch for overfitting with validation loss"
      ]
    },
    {
      "id": "ex3",
      "title": "CNN Surface Code Decoder",
      "type": "coding",
      "difficulty": "advanced",
      "points": 25,
      "description": "Build a CNN decoder for surface codes.",
      "tasks": [
        "Reshape syndrome to 2D grid format",
        "Design CNN with 3-5 conv layers",
        "Ensure sufficient receptive field",
        "Train and evaluate logical error rate",
        "Test generalization to different error rates"
      ],
      "expectedOutput": "CNN decoder for surface codes",
      "hints": [
        "Separate X and Z syndromes into channels",
        "Use padding to maintain spatial size",
        "Receptive field ≥ code distance d",
        "Use dilated convolutions for larger reach"
      ]
    },
    {
      "id": "ex4",
      "title": "RL Decoder Agent",
      "type": "coding",
      "difficulty": "advanced",
      "points": 25,
      "description": "Implement an RL agent for decoding.",
      "tasks": [
        "Define environment: state=syndrome, action=flip qubit",
        "Implement Q-learning or policy gradient",
        "Design reward: +1 success, -1 logical error",
        "Train agent on small codes (d=3)",
        "Evaluate learned policy"
      ],
      "expectedOutput": "RL decoding agent",
      "hints": [
        "Start with tabular Q-learning for d=3",
        "Use epsilon-greedy exploration",
        "Episode ends when syndrome=0 or max steps",
        "Track success rate during training"
      ]
    }
  ]
}
