{
  "exerciseId": "04-06-01-topological-overview-exercises",
  "title": "Exercises: Introduction to Topological Codes",
  "exercises": [
    {
      "id": "ex1",
      "title": "Euler Characteristic Calculator",
      "type": "coding",
      "difficulty": "beginner",
      "points": 20,
      "description": "Compute topological invariants for code lattices.",
      "tasks": [
        "Implement Euler characteristic χ = V - E + F",
        "Calculate genus from Euler characteristic",
        "Determine number of logical qubits",
        "Analyze various code topologies",
        "Handle surfaces with boundaries"
      ],
      "expectedOutput": "Topological invariant calculator",
      "hints": [
        "χ = 2 - 2g for closed surfaces",
        "χ = 2 - 2g - b for surfaces with b boundaries",
        "k = 2g for closed, k = 1 for planar with alternating boundaries",
        "Count elements carefully for different lattices"
      ]
    },
    {
      "id": "ex2",
      "title": "Topology Visualizer",
      "type": "coding",
      "difficulty": "intermediate",
      "points": 25,
      "description": "Visualize topological code structures.",
      "tasks": [
        "Draw planar surface code with boundaries",
        "Draw toric code with periodic boundaries",
        "Mark non-trivial cycles (logical operators)",
        "Show anyon positions (syndromes)",
        "Animate anyon braiding"
      ],
      "expectedOutput": "Interactive topology visualization",
      "hints": [
        "Use ASCII or matplotlib for visualization",
        "Toric: wrap around in both directions",
        "Non-trivial cycles span the system",
        "Anyons move along edges"
      ]
    },
    {
      "id": "ex3",
      "title": "Code Family Comparator",
      "type": "coding",
      "difficulty": "intermediate",
      "points": 25,
      "description": "Compare different topological code families.",
      "tasks": [
        "Compute parameters for surface codes (planar/toric)",
        "Compute parameters for color codes",
        "Compare encoding rates for same distance",
        "Analyze threshold differences",
        "Generate comparison tables and plots"
      ],
      "expectedOutput": "Comprehensive code comparison tool",
      "hints": [
        "Surface: n = d², k = 1, rate = 1/d²",
        "Toric: n = 2d², k = 2, rate = 1/d²",
        "Color: more complex structure",
        "Plot rate vs distance for each family"
      ]
    },
    {
      "id": "ex4",
      "title": "Anyon Dynamics Simulator",
      "type": "coding",
      "difficulty": "advanced",
      "points": 30,
      "description": "Simulate anyon creation, movement, and fusion.",
      "tasks": [
        "Model e and m anyon types",
        "Implement anyon creation from errors",
        "Track anyon movement (error chain extension)",
        "Implement anyon fusion (annihilation)",
        "Compute braiding phases"
      ],
      "expectedOutput": "Anyon physics simulator",
      "hints": [
        "e anyons from X errors, m from Z errors",
        "e × e = 1, m × m = 1 (fusion rules)",
        "e around m gives -1 phase",
        "Track world lines through space-time"
      ]
    }
  ]
}
