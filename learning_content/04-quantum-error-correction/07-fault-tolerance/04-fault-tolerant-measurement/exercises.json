{
  "exerciseId": "04-07-04-fault-tolerant-measurement-exercises",
  "title": "Exercises: Fault-Tolerant Measurement",
  "exercises": [
    {
      "id": "ex1",
      "title": "Shor-Style Circuit Builder",
      "type": "coding",
      "difficulty": "intermediate",
      "points": 25,
      "description": "Implement Shor-style syndrome extraction circuits.",
      "tasks": [
        "Generate Shor-style circuit for weight-4 stabilizer",
        "Count ancilla qubits used",
        "Analyze error propagation from each fault location",
        "Verify single fault causes single data error",
        "Compare to naive circuit"
      ],
      "expectedOutput": "Shor-style circuit with fault analysis",
      "hints": [
        "One ancilla per data qubit in stabilizer",
        "Each ancilla controls one CNOT",
        "Syndrome = parity of ancilla measurements",
        "Trace X errors through CNOTs"
      ]
    },
    {
      "id": "ex2",
      "title": "Cat State Verifier",
      "type": "coding",
      "difficulty": "intermediate",
      "points": 25,
      "description": "Implement verified cat state preparation.",
      "tasks": [
        "Generate cat state (|0...0⟩ + |1...1⟩)/√2",
        "Add parity verification checks",
        "Simulate with X errors",
        "Track verification success/failure",
        "Calculate discard rate vs error rate"
      ],
      "expectedOutput": "Verified cat state generator with statistics",
      "hints": [
        "Cat state: H then cascade of CNOTs",
        "Verify: CNOT pairs to ancilla, measure",
        "Single X error flips one parity",
        "If any check fails, discard"
      ]
    },
    {
      "id": "ex3",
      "title": "3D Syndrome Decoder",
      "type": "coding",
      "difficulty": "advanced",
      "points": 25,
      "description": "Build decoder for repeated measurements.",
      "tasks": [
        "Simulate d rounds of syndrome measurement",
        "Inject data and measurement errors",
        "Build 3D syndrome graph",
        "Detect temporal vs spatial defect pairs",
        "Apply matching to find corrections"
      ],
      "expectedOutput": "Working 3D syndrome decoder",
      "hints": [
        "Measurement error: defect pair in time",
        "Data error: defect pair in space",
        "Graph has edges in 3D",
        "Match defects to minimize total weight"
      ]
    },
    {
      "id": "ex4",
      "title": "Complete FT Syndrome Protocol",
      "type": "coding",
      "difficulty": "advanced",
      "points": 25,
      "description": "Implement full fault-tolerant syndrome extraction.",
      "tasks": [
        "Prepare and verify cat states",
        "Extract syndrome using cats",
        "Repeat for d rounds",
        "Decode syndrome history",
        "Output correction and logical outcome"
      ],
      "expectedOutput": "Complete FT syndrome protocol",
      "hints": [
        "Discard bad cat states",
        "Record all d rounds",
        "Use 3D matching",
        "Track Pauli frame classically"
      ]
    }
  ]
}
