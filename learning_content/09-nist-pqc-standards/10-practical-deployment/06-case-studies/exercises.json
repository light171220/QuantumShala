      "title": "Deployment Plan Generator",
      "type": "coding",
      "difficulty": "intermediate",
      "points": 30,
      "description": "Build a deployment plan generator based on case study lessons.",
      "tasks": [
        "Define organization profile inputs",
        "Apply industry-specific recommendations",
        "Generate timeline with phases",
        "Include risk mitigation strategies",
        "Output comprehensive deployment plan"
      ],
      "expectedOutput": "Customized PQC deployment plan generator",
      "hints": [
        "Include lessons learned from case studies",
        "Adjust timelines based on organization size",
        "Add regulatory requirements by industry",
        "Include resource estimation"
      ]
    },
    {
