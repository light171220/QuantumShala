      "type": "coding",
      "difficulty": "intermediate",
      "points": 25,
      "description": "Create a tool to analyze and compare PQC deployment case studies.",
      "tasks": [
        "Define case study data structure",
        "Compare timelines across studies",
        "Extract common challenges",
        "Identify success patterns",
        "Generate comparative report"
      ],
      "expectedOutput": "Case study analysis and comparison tool",
      "hints": [
        "Store structured case study data",
        "Calculate average timelines by phase",
        "Use keyword extraction for challenges",
        "Rank lessons by frequency"
      ]
    },
    {
      "id": "ex3",
      "title": "Lessons Learned Tracker",
      "type": "coding",
      "difficulty": "beginner",
      "points": 25,
      "description": "Build a lessons learned tracking system.",
      "tasks": [
        "Define lesson categories",
        "Store lessons with context",
        "Filter by priority and category",
        "Generate checklist from lessons",
