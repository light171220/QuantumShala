  "exercises": [
    {
      "id": "ex1",
      "title": "Handshake Diagnostic Tool",
      "type": "coding",
      "difficulty": "intermediate",
      "points": 30,
      "description": "Build a comprehensive TLS handshake diagnostic tool for PQC.",
      "tasks": [
        "Check TCP connectivity",
        "Verify TLS version negotiation",
        "Test key exchange group support",
        "Validate certificate chain",
        "Generate detailed diagnostic report"
      ],
      "expectedOutput": "Handshake diagnostic tool with failure identification",
      "hints": [
        "Use subprocess to call openssl s_client",
        "Parse output for specific error messages",
        "Include remediation suggestions",
        "Support testing specific algorithm groups"
      ]
    },
    {
      "id": "ex2",
      "title": "Performance Profiler",
      "type": "coding",
      "difficulty": "advanced",
      "points": 30,
      "description": "Create a performance profiling tool for PQC operations.",
      "tasks": [
        "Measure individual handshake phases",
        "Compare against classical baselines",
        "Identify bottlenecks",
        "Track performance over multiple runs",
        "Generate optimization suggestions"
      ],
      "expectedOutput": "Performance profiler with bottleneck identification",
      "hints": [
        "Use high-resolution timers",
        "Calculate percentiles for latency",
        "Distinguish between network and crypto time",
        "Include CPU utilization metrics"
      ]
    },
    {
      "id": "ex3",
      "title": "Certificate Chain Analyzer",
      "type": "coding",
      "difficulty": "intermediate",
      "points": 25,
      "description": "Build a certificate chain analyzer for PQC certificates.",
      "tasks": [
        "Parse certificate chain",
        "Calculate total and individual sizes",
        "Check against TLS size limits",
        "Verify algorithm support",
        "Suggest size optimizations"
      ],
      "expectedOutput": "Certificate analyzer with size recommendations",
      "hints": [
        "Parse PEM-encoded certificates",
        "Extract signature algorithm and key size",
        "Compare ML-DSA vs SLH-DSA sizes",
        "Recommend chain depth reduction"
      ]
    },
    {
      "id": "ex4",
      "title": "Client Compatibility Checker",
      "type": "coding",
      "difficulty": "beginner",
      "points": 15,
      "description": "Create a client compatibility checking tool.",
      "tasks": [
        "Parse user agent strings",
        "Match against known client capabilities",
        "Report PQC support status",
        "Calculate PQC-capable traffic percentage",
        "Suggest server configuration"
      ],
      "expectedOutput": "Client compatibility checker with traffic analysis",
      "hints": [
        "Build database of known clients",
        "Handle version number parsing",
        "Support unknown client detection",
        "Recommend fallback configuration"
      ]
