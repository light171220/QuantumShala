{
  "exerciseId": "09-05-audit-documentation-exercises",
  "title": "Exercises: Audit and Documentation",
  "exercises": [
    {
      "id": "ex1",
      "title": "Cryptographic Policy Generator",
      "type": "coding",
      "difficulty": "intermediate",
      "points": 30,
      "description": "Create a tool to generate cryptographic policy documents.",
      "tasks": [
        "Define policy template structure",
        "Input organization and approval information",
        "Add approved/deprecated algorithm entries",
        "Include key management requirements",
        "Generate formatted policy document"
      ],
      "expectedOutput": "Policy document generator with customizable templates",
      "hints": [
        "Include version control information",
        "Add sunset dates for deprecated algorithms",
        "Reference applicable standards (FIPS, CNSA)",
        "Include exceptions process section"
      ]
    },
    {
      "id": "ex2",
      "title": "Audit Logging System",
      "type": "coding",
      "difficulty": "intermediate",
      "points": 25,
      "description": "Implement an audit logging system for cryptographic operations.",
      "tasks": [
        "Define audit event types and structure",
        "Implement secure log writing",
        "Add query capability by time and type",
        "Generate audit reports for periods",
        "Ensure log integrity protection"
      ],
      "expectedOutput": "Audit logging system with query and reporting",
      "hints": [
        "Log all key management events",
        "Include timestamp, user, result, details",
        "Never log secret key values",
        "Consider log rotation and retention"
      ]
    },
    {
      "id": "ex3",
      "title": "Evidence Collection Checklist",
      "type": "coding",
      "difficulty": "beginner",
      "points": 25,
      "description": "Build an evidence collection checklist for PQC audits.",
      "tasks": [
        "Define evidence categories (technical, process, management)",
        "List required evidence items per category",
        "Track collection status",
        "Link evidence to requirements",
        "Generate collection progress report"
      ],
      "expectedOutput": "Evidence collection tracking system",
      "hints": [
        "Map evidence to FIPS/CC requirements",
        "Include CAVP certificates in technical",
        "Track policy approvals in management",
        "Note evidence freshness requirements"
      ]
    },
    {
      "id": "ex4",
      "title": "Compliance Report Generator",
      "type": "coding",
      "difficulty": "intermediate",
      "points": 20,
      "description": "Create an automated compliance report generator.",
      "tasks": [
        "Aggregate data from audit logs",
        "Include policy compliance status",
        "Summarize algorithm usage",
        "Highlight exceptions and issues",
        "Generate executive summary"
      ],
      "expectedOutput": "Automated compliance report generator",
      "hints": [
        "Pull from multiple data sources",
        "Include trend analysis",
        "Highlight non-compliant items",
        "Format for different audiences"
      ]
    }
  ]
}
