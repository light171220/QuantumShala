{
  "exerciseId": "09-06-compliance-roadmap-exercises",
  "title": "Exercises: PQC Compliance Roadmap",
  "exercises": [
    {
      "id": "ex1",
      "title": "Roadmap Builder Tool",
      "type": "coding",
      "difficulty": "intermediate",
      "points": 30,
      "description": "Build a comprehensive PQC compliance roadmap planning tool.",
      "tasks": [
        "Define phases with default milestones",
        "Allow customization of timeline",
        "Track dependencies between milestones",
        "Calculate critical path",
        "Generate visual timeline"
      ],
      "expectedOutput": "Roadmap builder with timeline visualization",
      "hints": [
        "Include standard phases: Assessment through Sustainment",
        "Allow milestone date adjustment",
        "Validate dependencies",
        "Export to Gantt chart format"
      ]
    },
    {
      "id": "ex2",
      "title": "System Migration Prioritizer",
      "type": "coding",
      "difficulty": "intermediate",
      "points": 25,
      "description": "Create a tool to prioritize systems for PQC migration.",
      "tasks": [
        "Input system attributes (sensitivity, complexity, regulatory)",
        "Define prioritization scoring algorithm",
        "Rank systems by migration priority",
        "Assign to migration waves",
        "Generate migration schedule"
      ],
      "expectedOutput": "System prioritization and wave planning tool",
      "hints": [
        "Weight factors by importance",
        "Consider dependencies between systems",
        "Balance waves by resource capacity",
        "Align with regulatory deadlines"
      ]
    },
    {
      "id": "ex3",
      "title": "Progress Dashboard",
      "type": "coding",
      "difficulty": "intermediate",
      "points": 25,
      "description": "Build a progress tracking dashboard for the roadmap.",
      "tasks": [
        "Calculate phase completion percentages",
        "Track schedule variance",
        "Highlight overdue milestones",
        "Show upcoming deadlines",
        "Generate status reports"
      ],
      "expectedOutput": "Progress tracking dashboard with reporting",
      "hints": [
        "Use visual indicators (progress bars)",
        "Color-code by status (red/yellow/green)",
        "Include trend analysis",
        "Support weekly status updates"
      ]
    },
    {
      "id": "ex4",
      "title": "Resource Planning Calculator",
      "type": "analysis",
      "difficulty": "beginner",
      "points": 20,
      "description": "Create a resource planning calculator for PQC migration.",
      "tasks": [
        "Define resource types needed per phase",
        "Estimate FTE requirements",
        "Calculate budget by phase",
        "Identify skill gaps",
        "Generate hiring/training plan"
      ],
      "expectedOutput": "Resource planning calculator with budget estimates",
      "hints": [
        "Include internal and external resources",
        "Factor in FIPS validation costs",
        "Consider training needs",
        "Add contingency buffer"
      ]
    }
  ]
}
