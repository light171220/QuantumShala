{
  "exerciseId": "09-04-industry-standards-exercises",
  "title": "Exercises: Industry Standards and Guidelines",
  "exercises": [
    {
      "id": "ex1",
      "title": "IETF Draft Tracker",
      "type": "coding",
      "difficulty": "intermediate",
      "points": 30,
      "description": "Build a tracker for IETF PQC-related documents.",
      "tasks": [
        "Define draft document data structure",
        "Track status (draft, WG adopted, RFC)",
        "Filter by working group and algorithm",
        "Alert on status changes",
        "Generate progress report"
      ],
      "expectedOutput": "IETF PQC document tracking system",
      "hints": [
        "Include key documents from LAMPS, TLS, PQUIP",
        "Track expected RFC dates",
        "Link to datatracker URLs",
        "Note dependencies between drafts"
      ]
    },
    {
      "id": "ex2",
      "title": "Sector Standards Mapper",
      "type": "coding",
      "difficulty": "intermediate",
      "points": 25,
      "description": "Create a mapper for sector-specific PQC requirements.",
      "tasks": [
        "Define sectors and their relevant standards",
        "Map current crypto requirements",
        "Identify PQC update status",
        "Generate sector compliance checklist",
        "Track timeline for each requirement"
      ],
      "expectedOutput": "Sector standards mapping tool",
      "hints": [
        "Cover financial, healthcare, energy, telecom",
        "Include regulatory requirements (HIPAA, PCI, etc.)",
        "Note which follow federal guidance",
        "Identify sector-specific concerns"
      ]
    },
    {
      "id": "ex3",
      "title": "Standards Alert System",
      "type": "coding",
      "difficulty": "beginner",
      "points": 25,
      "description": "Design an alert system for PQC standards updates.",
      "tasks": [
        "Define sources to monitor (IETF, NIST, ISO)",
        "Create subscription preferences",
        "Filter by relevance to organization",
        "Generate periodic digest",
        "Highlight critical updates"
      ],
      "expectedOutput": "Standards monitoring alert system design",
      "hints": [
        "RSS feeds from key sources",
        "Keyword filtering for PQC terms",
        "Priority levels for different sources",
        "Weekly vs. immediate alerts"
      ]
    },
    {
      "id": "ex4",
      "title": "Interoperability Test Plan",
      "type": "analysis",
      "difficulty": "intermediate",
      "points": 20,
      "description": "Design an interoperability test plan based on IETF drafts.",
      "tasks": [
        "Identify key interop requirements from drafts",
        "Define test cases for TLS hybrid",
        "Define test cases for X.509 certificates",
        "Create test harness requirements",
        "Document expected results"
      ],
      "expectedOutput": "PQC interoperability test plan",
      "hints": [
        "Reference IETF hackathon test vectors",
        "Include both positive and negative tests",
        "Test algorithm negotiation",
        "Verify certificate chain validation"
      ]
    }
  ]
}
