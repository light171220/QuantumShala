{
  "exerciseId": "07-08-06-standards-exercises",
  "title": "Exercises: Security Standards and Certification",
  "exercises": [
    {
      "id": "ex1",
      "title": "Standards Compliance Checker",
      "type": "coding",
      "difficulty": "beginner",
      "points": 20,
      "description": "Build a tool to check compliance against QKD standards.",
      "tasks": [
        "Define major QKD standards (ETSI, ISO, ITU)",
        "List requirements for each standard",
        "Input implementation evidence",
        "Calculate compliance score per standard",
        "Generate compliance report"
      ],
      "expectedOutput": "Standards compliance checking tool",
      "hints": [
        "ETSI has multiple QKD-specific standards",
        "Each standard has different requirements",
        "Partial compliance is possible",
        "Track missing requirements clearly"
      ]
    },
    {
      "id": "ex2",
      "title": "Certification Readiness Assessment",
      "type": "coding",
      "difficulty": "intermediate",
      "points": 30,
      "description": "Assess readiness for QKD system certification.",
      "tasks": [
        "Define certification requirements by category",
        "Specify evidence needed for each requirement",
        "Evaluate provided evidence",
        "Identify gaps and missing evidence",
        "Estimate effort to achieve readiness"
      ],
      "expectedOutput": "Certification readiness assessment tool",
      "hints": [
        "Categories: proofs, implementation, testing, operations",
        "Higher assurance levels need more evidence",
        "Some evidence is prerequisite for others",
        "Prioritize critical gaps"
      ]
    },
    {
      "id": "ex3",
      "title": "Security Evaluation Test Suite",
      "type": "coding",
      "difficulty": "intermediate",
      "points": 25,
      "description": "Design a security evaluation test framework.",
      "tasks": [
        "Define test categories (optical, side-channel, etc.)",
        "Specify tests per category",
        "Create pass/fail criteria",
        "Calculate category and overall scores",
        "Generate evaluation report"
      ],
      "expectedOutput": "Security evaluation test framework",
      "hints": [
        "Include quantum-specific tests",
        "Set clear pass thresholds",
        "Weight categories by importance",
        "Document test methodology"
      ]
    },
    {
      "id": "ex4",
      "title": "Compliance Documentation Generator",
      "type": "coding",
      "difficulty": "advanced",
      "points": 25,
      "description": "Generate compliance documentation templates.",
      "tasks": [
        "Define document types (security target, test reports)",
        "Create document structure templates",
        "Auto-populate from system data",
        "Validate completeness",
        "Export in required formats"
      ],
      "expectedOutput": "Compliance documentation generator",
      "hints": [
        "Security Target has specific sections",
        "Test reports need methodology and results",
        "Link evidence to requirements",
        "Include version and date tracking"
      ]
    }
  ]
}
