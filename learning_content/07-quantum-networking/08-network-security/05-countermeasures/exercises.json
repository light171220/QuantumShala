{
  "exerciseId": "07-08-05-countermeasures-exercises",
  "title": "Exercises: Countermeasures and Defenses",
  "exercises": [
    {
      "id": "ex1",
      "title": "Countermeasure Effectiveness Calculator",
      "type": "coding",
      "difficulty": "beginner",
      "points": 20,
      "description": "Calculate combined effectiveness of multiple countermeasures.",
      "tasks": [
        "Define countermeasure catalog with effectiveness ratings",
        "Calculate individual bypass probability",
        "Combine multiple countermeasures (multiplicative)",
        "Identify coverage gaps",
        "Generate protection report"
      ],
      "expectedOutput": "Countermeasure effectiveness analysis tool",
      "hints": [
        "Bypass probability = 1 - effectiveness",
        "Combined bypass = product of individual bypasses",
        "Some attacks need specific countermeasures",
        "Consider cost vs protection tradeoff"
      ]
    },
    {
      "id": "ex2",
      "title": "Security Monitoring Dashboard",
      "type": "coding",
      "difficulty": "intermediate",
      "points": 30,
      "description": "Build a real-time security monitoring system.",
      "tasks": [
        "Define baselines for key parameters",
        "Implement anomaly detection with thresholds",
        "Create attack signature matcher",
        "Generate alerts with severity levels",
        "Recommend response actions"
      ],
      "expectedOutput": "Security monitoring dashboard",
      "hints": [
        "Track QBER, power, detection rates, timing",
        "Use statistical thresholds (e.g., 3 sigma)",
        "Combine indicators for signature matching",
        "Critical alerts should abort session"
      ]
    },
    {
      "id": "ex3",
      "title": "MDI-QKD Simulator",
      "type": "coding",
      "difficulty": "intermediate",
      "points": 25,
      "description": "Simulate MDI-QKD protocol showing detector attack immunity.",
      "tasks": [
        "Implement Alice and Bob state preparation",
        "Simulate Charlie's Bell state measurement",
        "Show key correlation process",
        "Demonstrate that Charlie learns nothing",
        "Compare key rate to standard QKD"
      ],
      "expectedOutput": "MDI-QKD protocol simulation",
      "hints": [
        "BSM only succeeds when bases match",
        "Charlie announces which Bell state detected",
        "Alice and Bob correlate based on announcement",
        "Key rate is lower than standard QKD"
      ]
    },
    {
      "id": "ex4",
      "title": "Defense-in-Depth Planner",
      "type": "coding",
      "difficulty": "advanced",
      "points": 25,
      "description": "Design a multi-layer defense strategy for QKD system.",
      "tasks": [
        "Input threat model (expected attacks)",
        "Select countermeasures for each layer",
        "Calculate overall protection level",
        "Identify remaining vulnerabilities",
        "Generate implementation plan"
      ],
      "expectedOutput": "Complete defense-in-depth strategy",
      "hints": [
        "Layers: protocol, device, monitoring, operational",
        "Each layer should address different attacks",
        "No single point of failure",
        "Balance security vs complexity/cost"
      ]
    }
  ]
