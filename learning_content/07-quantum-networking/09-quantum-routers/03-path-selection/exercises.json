{
  "exerciseId": "07-09-03-path-selection-exercises",
  "title": "Exercises: Path Selection Algorithms",
  "exercises": [
    {
      "id": "ex1",
      "title": "Fidelity-Optimal Path Finder",
      "type": "coding",
      "difficulty": "beginner",
      "points": 20,
      "description": "Implement Dijkstra's algorithm for fidelity optimization.",
      "tasks": [
        "Convert fidelity to additive cost using -log",
        "Implement modified Dijkstra's algorithm",
        "Track path and total fidelity",
        "Handle unreachable destinations",
        "Compare with hop-count shortest path"
      ],
      "expectedOutput": "Fidelity-optimized path finder",
      "hints": [
        "-log(a×b) = -log(a) + -log(b)",
        "Use min-heap priority queue",
        "Reconstruct path from predecessors",
        "Return None if no path exists"
      ]
    },
    {
      "id": "ex2",
      "title": "Multi-Metric Path Selector",
      "type": "coding",
      "difficulty": "intermediate",
      "points": 30,
      "description": "Select paths considering multiple metrics.",
      "tasks": [
        "Define weighted cost function",
        "Implement weighted path selection",
        "Allow configurable weights",
        "Compare paths under different weights",
        "Analyze trade-offs between metrics"
      ],
      "expectedOutput": "Multi-metric path selector with trade-off analysis",
      "hints": [
        "Normalize metrics to same scale",
        "Weights sum to 1.0 for clarity",
        "Edge cases: weight = 0 or 1",
        "Show how weights affect choice"
      ]
    },
    {
      "id": "ex3",
      "title": "Constrained Path Optimizer",
      "type": "coding",
      "difficulty": "intermediate",
      "points": 25,
      "description": "Find optimal paths subject to constraints.",
      "tasks": [
        "Define constraint types (min fidelity, max latency)",
        "Prune paths violating constraints early",
        "Find best feasible path",
        "Report if no path meets constraints",
        "Suggest relaxed constraints if infeasible"
      ],
      "expectedOutput": "Constrained optimization with feasibility analysis",
      "hints": [
        "Prune during search, not after",
        "Track why paths were pruned",
        "Feasibility = constraints can be met",
        "Suggest minimum constraint relaxation"
      ]
    },
    {
      "id": "ex4",
      "title": "Quantum Routing Protocol",
      "type": "coding",
      "difficulty": "advanced",
      "points": 25,
      "description": "Implement a link-state routing protocol for quantum networks.",
      "tasks": [
        "Model link state advertisements",
        "Distribute link state updates",
        "Build network topology from updates",
        "Compute and maintain routing tables",
        "Handle topology changes dynamically"
      ],
      "expectedOutput": "Complete quantum routing protocol implementation",
      "hints": [
        "Each node advertises its links",
        "Flooding spreads updates network-wide",
        "Recompute routes on changes",
        "Include quantum-specific metrics in advertisements"
      ]
    }
  ]
}
