{
  "exerciseId": "07-09-05-multi-path-routing-exercises",
  "title": "Exercises: Multi-Path Routing",
  "exercises": [
    {
      "id": "ex1",
      "title": "Path Diversity Finder",
      "type": "coding",
      "difficulty": "beginner",
      "points": 20,
      "description": "Find and classify diverse paths in a network.",
      "tasks": [
        "Find all paths between two nodes",
        "Classify paths as disjoint, link-disjoint, or overlapping",
        "Select k most diverse paths",
        "Calculate diversity score",
        "Visualize path overlap"
      ],
      "expectedOutput": "Path diversity analysis tool",
      "hints": [
        "Node-disjoint = no shared intermediate nodes",
        "Link-disjoint = no shared edges",
        "Diversity score = inverse of overlap",
        "Prefer disjoint for reliability"
      ]
    },
    {
      "id": "ex2",
      "title": "Load Balancer Simulator",
      "type": "coding",
      "difficulty": "intermediate",
      "points": 30,
      "description": "Implement and compare load balancing policies.",
      "tasks": [
        "Implement round-robin, weighted, least-loaded policies",
        "Simulate request streams",
        "Measure load distribution per policy",
        "Calculate utilization and fairness",
        "Recommend policy for scenarios"
      ],
      "expectedOutput": "Load balancer with policy comparison",
      "hints": [
        "Track per-path load over time",
        "Weighted uses capacity proportions",
        "Least-loaded needs current state",
        "Measure variance for fairness"
      ]
    },
    {
      "id": "ex3",
      "title": "Fault-Tolerant Router",
      "type": "coding",
      "difficulty": "intermediate",
      "points": 25,
      "description": "Build fault-tolerant routing with automatic failover.",
      "tasks": [
        "Track path health status",
        "Implement failure detection",
        "Automatic failover to backup paths",
        "Path recovery detection",
        "Report availability statistics"
      ],
      "expectedOutput": "Fault-tolerant router with health monitoring",
      "hints": [
        "Use failure count threshold",
        "Mark unhealthy after repeated failures",
        "Probe for recovery periodically",
        "Log all failover events"
      ]
    },
    {
      "id": "ex4",
      "title": "Purification-Aware Path Selector",
      "type": "coding",
      "difficulty": "advanced",
      "points": 25,
      "description": "Select paths to optimize purification potential.",
      "tasks": [
        "Find independent path pairs",
        "Estimate purified fidelity",
        "Balance path count vs quality",
        "Calculate resource cost",
        "Recommend optimal path set"
      ],
      "expectedOutput": "Purification-optimized path selector",
      "hints": [
        "Independent errors enable purification",
        "More paths = more pairs to purify",
        "Diminishing returns on many paths",
        "Consider total resource consumption"
      ]
    }
  ]
}
