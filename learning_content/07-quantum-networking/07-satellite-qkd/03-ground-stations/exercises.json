      "type": "coding",
      "difficulty": "intermediate",
      "points": 25,
      "description": "Calculate complete ground station collection efficiency.",
      "tasks": [
        "Model telescope collection area",
        "Include optical path losses",
        "Add filtering transmission",
        "Include detector efficiency",
        "Calculate total system efficiency"
      ],
      "expectedOutput": "Complete collection efficiency calculator",
      "hints": [
        "Telescope efficiency ~80%",
        "Spectral filter ~90% transmission",
        "Fiber coupling ~50%",
        "Multiply all efficiencies for total"
      ]
    },
    {
      "id": "ex2",
      "title": "Site Selection Optimizer",
      "type": "coding",
      "difficulty": "intermediate",
      "points": 30,
      "description": "Build a tool to evaluate and rank ground station sites.",
      "tasks": [
        "Define scoring criteria with weights",
        "Input site parameters",
        "Calculate weighted scores",
        "Rank multiple sites",
        "Generate recommendation report"
      ],
      "expectedOutput": "Site selection decision tool",
      "hints": [
        "Weather is often most important factor",
        "Consider infrastructure availability",
        "Latitude affects satellite visibility",
        "Balance scientific vs practical needs"
      ]
    },
    {
      "id": "ex3",
      "title": "Tracking System Simulator",
      "type": "coding",
      "difficulty": "advanced",
      "points": 25,
      "description": "Simulate satellite tracking requirements and performance.",
      "tasks": [
        "Model satellite apparent motion",
        "Calculate mount velocity requirements",
        "Simulate beacon tracking loop",
        "Include atmospheric effects on tracking",
        "Determine tracking error statistics"
      ],
      "expectedOutput": "Tracking system simulation",
      "hints": [
        "LEO satellite moves ~1°/s at zenith",
        "Angular velocity varies with elevation",
        "Tracking loop bandwidth ~10-100 Hz",
        "Atmosphere causes ~1 arcsec wander"
      ]
    },
