{
  "exerciseId": "07-10-02-quantum-internet-vision-exercises",
  "title": "Exercises: Vision for the Quantum Internet",
  "exercises": [
    {
      "id": "ex1",
      "title": "Development Stage Mapper",
      "type": "coding",
      "difficulty": "beginner",
      "points": 20,
      "description": "Map applications to required quantum internet stages.",
      "tasks": [
        "Define 7 network stages and capabilities",
        "List applications enabled at each stage",
        "Input desired application",
        "Determine minimum required stage",
        "Generate readiness timeline"
      ],
      "expectedOutput": "Application to stage mapping tool",
      "hints": [
        "Stages build on previous capabilities",
        "Higher stages enable more applications",
        "Some applications have multiple implementations",
        "Timeline based on technology readiness"
      ]
    },
    {
      "id": "ex2",
      "title": "Global Architecture Simulator",
      "type": "coding",
      "difficulty": "intermediate",
      "points": 30,
      "description": "Simulate global quantum internet architecture.",
      "tasks": [
        "Model hierarchical network (satellite, backbone, metro, access)",
        "Calculate entanglement paths between cities",
        "Estimate end-to-end fidelity and latency",
        "Handle satellite vs fiber routing",
        "Generate global connectivity map"
      ],
      "expectedOutput": "Global quantum network simulator",
      "hints": [
        "Satellites for intercontinental links",
        "Fiber within continents with repeaters",
        "Path fidelity is product of segments",
        "Consider time-of-day for satellites"
      ]
    },
    {
      "id": "ex3",
      "title": "Application Impact Analyzer",
      "type": "coding",
      "difficulty": "intermediate",
      "points": 25,
      "description": "Analyze societal impact of quantum internet applications.",
      "tasks": [
        "Define application categories and benefits",
        "Quantify potential impact (users, economic)",
        "Identify dependencies and prerequisites",
        "Map rollout timeline",
        "Generate impact report"
      ],
      "expectedOutput": "Application impact analysis tool",
      "hints": [
        "Security apps earliest, computing later",
        "Economic impact varies by sector",
        "Some apps enable others",
        "Consider adoption barriers"
      ]
    },
    {
      "id": "ex4",
      "title": "Quantum Internet Capability Planner",
      "type": "coding",
      "difficulty": "advanced",
      "points": 25,
      "description": "Plan capability deployment for quantum internet project.",
      "tasks": [
        "Input target applications",
        "Determine required stages",
        "Identify technology gaps",
        "Create development roadmap",
        "Estimate investment needed"
      ],
      "expectedOutput": "Capability deployment planner",
      "hints": [
        "Work backwards from application needs",
        "Identify critical path technologies",
        "Consider parallel development tracks",
        "Include testing and validation phases"
      ]
    }
  ]
}
