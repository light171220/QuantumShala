      "id": "ex1",
      "title": "Coexistence Analyzer",
      "type": "coding",
      "difficulty": "beginner",
      "points": 20,
      "description": "Analyze quantum-classical fiber coexistence feasibility.",
      "tasks": [
        "Model Raman scattering noise from classical channels",
        "Calculate noise at quantum wavelength",
        "Check against quantum sensitivity threshold",
        "Recommend coexistence mode",
        "Generate feasibility report"
      ],
      "expectedOutput": "Fiber coexistence feasibility analyzer",
      "hints": [
        "Raman noise scales with power and distance",
        "Spectral separation provides isolation",
        "More classical channels = more noise",
        "Some scenarios require separate fiber"
      ]
    },
    {
