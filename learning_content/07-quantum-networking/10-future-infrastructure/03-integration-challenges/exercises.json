      "difficulty": "intermediate",
      "points": 30,
      "description": "Assess site readiness for quantum network deployment.",
      "tasks": [
        "Define checklist of requirements",
        "Input site conditions",
        "Score readiness by category",
        "Identify gaps and priorities",
        "Generate remediation plan"
      ],
      "expectedOutput": "Comprehensive site readiness assessment",
      "hints": [
        "Categories: physical, technical, operational, organizational",
        "Weight challenges by severity",
        "Prioritize high-severity gaps",
        "Include cost estimates for remediation"
      ]
    },
    {
