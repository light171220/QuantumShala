      "difficulty": "advanced",
      "points": 25,
      "description": "Model costs of quantum network integration.",
      "tasks": [
        "Categorize integration costs",
        "Model fiber/infrastructure costs",
        "Add equipment and training costs",
        "Calculate TCO over time horizon",
        "Compare deployment approaches"
      ],
      "expectedOutput": "Integration cost model with TCO analysis",
      "hints": [
