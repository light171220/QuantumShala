{
  "exerciseId": "07-03-01-bb84-basics-exercises",
  "title": "Exercises: BB84 Protocol Basics",
  "exercises": [
    {
      "id": "ex1",
      "title": "BB84 State Simulator",
      "type": "coding",
      "difficulty": "beginner",
      "points": 25,
      "description": "Implement BB84 quantum states with measurement.",
      "tasks": [
        "Create state vectors for all four BB84 states",
        "Implement measurement in arbitrary basis",
        "Calculate overlap probabilities between states",
        "Visualize states on Bloch sphere",
        "Demonstrate basis mismatch randomness"
      ],
      "expectedOutput": "Complete BB84 state simulation",
      "hints": [
        "|0⟩ = [1, 0], |1⟩ = [0, 1]",
        "|+⟩ = [1, 1]/√2, |-⟩ = [1, -1]/√2",
        "Same basis → deterministic, different → random",
        "Use inner product for overlap"
      ]
    },
    {
      "id": "ex2",
      "title": "Full Protocol Simulator",
      "type": "coding",
      "difficulty": "intermediate",
      "points": 30,
      "description": "Build complete BB84 protocol simulation.",
      "tasks": [
        "Implement Alice's state preparation",
        "Implement Bob's measurement",
        "Add classical sifting phase",
        "Calculate and verify QBER",
        "Generate protocol statistics"
      ],
      "expectedOutput": "End-to-end BB84 simulation",
      "hints": [
        "Random bits and bases for Alice",
        "Random bases for Bob",
        "Keep indices where bases match",
        "QBER = errors / total in sample"
      ]
    },
    {
      "id": "ex3",
      "title": "Eavesdropper Impact Analyzer",
      "type": "coding",
      "difficulty": "intermediate",
      "points": 25,
      "description": "Analyze how eavesdropping affects BB84.",
      "tasks": [
        "Implement intercept-resend attack",
        "Calculate QBER as function of interception rate",
        "Compute Eve's information gain",
        "Plot information-disturbance tradeoff",
        "Determine detection probability"
      ],
      "expectedOutput": "Eavesdropping analysis tool",
      "hints": [
        "Eve intercepts fraction f of qubits",
        "QBER = 0.25 × f for full intercept-resend",
        "Eve learns bit when basis guess correct (50%)",
        "Detection probability increases with sample size"
      ]
    },
    {
      "id": "ex4",
      "title": "Protocol Visualizer",
      "type": "coding",
      "difficulty": "beginner",
      "points": 20,
      "description": "Create visual representation of BB84 execution.",
      "tasks": [
        "Display state preparation table",
        "Show basis comparison",
        "Highlight matched/mismatched positions",
        "Visualize sifting process",
        "Generate protocol summary report"
      ],
      "expectedOutput": "Interactive BB84 visualization",
      "hints": [
        "Use symbols for bases: ⊕ (Z), ⊗ (X)",
        "Color code matches vs mismatches",
        "Show before/after sifting",
        "Include statistics"
      ]
    }
  ]
}
