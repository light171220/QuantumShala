{
  "exerciseId": "07-03-02-basis-selection-exercises",
  "title": "Exercises: Basis Selection and Encoding",
  "exercises": [
    {
      "id": "ex1",
      "title": "MUB Calculator",
      "type": "coding",
      "difficulty": "intermediate",
      "points": 25,
      "description": "Build a tool to compute and verify mutually unbiased bases.",
      "tasks": [
        "Compute all three qubit MUBs (X, Y, Z eigenstates)",
        "Verify MUB property: |⟨a_i|b_j⟩|² = 1/2",
        "Calculate measurement probabilities for any state in any basis",
        "Visualize bases on Bloch sphere",
        "Extend to higher dimensions (if possible)"
      ],
      "expectedOutput": "MUB computation and verification tool",
      "hints": [
        "MUBs are eigenstates of Pauli matrices",
        "Inner product gives overlap probability",
        "For qutrit (d=3), there are 4 MUBs",
        "Use complex conjugate for inner product"
      ]
    },
    {
      "id": "ex2",
      "title": "Encoding Scheme Comparator",
      "type": "coding",
      "difficulty": "intermediate",
      "points": 25,
      "description": "Compare polarization and phase encoding schemes.",
      "tasks": [
        "Implement polarization state representation",
        "Implement phase/time-bin representation",
        "Model encoding/decoding operations",
        "Simulate channel effects on each encoding",
        "Compare stability and performance"
      ],
      "expectedOutput": "Encoding scheme comparison tool",
      "hints": [
        "Polarization: Jones vectors or Stokes parameters",
        "Phase: relative phase between paths/times",
        "Model PMD for polarization in fiber",
        "Phase more stable but complex setup"
      ]
    },
    {
      "id": "ex3",
      "title": "QRNG Quality Tester",
      "type": "coding",
      "difficulty": "advanced",
      "points": 30,
      "description": "Implement randomness tests for basis selection.",
      "tasks": [
        "Implement frequency (monobit) test",
        "Implement runs test for sequential patterns",
        "Calculate autocorrelation",
        "Test for χ² uniformity",
        "Generate randomness quality report"
      ],
      "expectedOutput": "Comprehensive QRNG testing suite",
      "hints": [
        "Frequency: count 0s vs 1s should be ~50/50",
        "Runs: transitions should be random",
        "Autocorrelation should be near zero",
        "NIST SP 800-22 has standard tests"
      ]
    },
    {
      "id": "ex4",
      "title": "Basis Reconciliation Simulator",
      "type": "coding",
      "difficulty": "beginner",
      "points": 20,
      "description": "Simulate the basis reconciliation protocol.",
      "tasks": [
        "Generate random bases for Alice and Bob",
        "Implement basis comparison",
        "Calculate sifting efficiency",
        "Extract matching positions",
        "Verify statistical properties"
      ],
      "expectedOutput": "Basis reconciliation simulation",
      "hints": [
        "Alice and Bob choose independently",
        "Match probability = 1/2 for 2 bases",
        "Keep indices where bases match",
        "~50% sifting efficiency expected"
      ]
    }
  ]
}
