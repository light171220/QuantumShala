  "title": "Exercises: BB84 Implementation",
  "exercises": [
    {
      "id": "ex1",
      "title": "Decoy-State Analyzer",
      "type": "coding",
      "difficulty": "advanced",
      "points": 30,
      "description": "Implement decoy-state BB84 with parameter estimation.",
      "tasks": [
        "Implement intensity randomization (signal, decoy, vacuum)",
        "Simulate detection with different intensities",
        "Calculate gains per intensity class",
        "Estimate single-photon yield and error rate",
        "Compare key rate with and without decoy"
      ],
      "expectedOutput": "Decoy-state BB84 simulation and analysis",
      "hints": [
        "Poisson: P(n) = μⁿ/n! × e^(-μ)",
        "Measure Q_μ, Q_ν, Q_ω separately",
        "Y₁ lower bound from decoy equations",
        "Decoy enables longer distance"
      ]
    },
    {
      "id": "ex2",
      "title": "Timing System Simulator",
      "type": "coding",
      "difficulty": "intermediate",
      "points": 25,
      "description": "Simulate BB84 timing and synchronization.",
      "tasks": [
        "Model fiber propagation delay",
        "Implement detection window gating",
        "Calculate jitter contributions",
        "Optimize window size for given jitter",
        "Analyze dark count vs signal tradeoff"
      ],
      "expectedOutput": "BB84 timing simulation",
      "hints": [
        "Fiber delay: ~5 μs/km",
        "Jitter combines as RSS (root sum squares)",
        "Window: ~3-4× total jitter",
        "Dark counts proportional to window"
      ]
    },
    {
      "id": "ex3",
      "title": "Complete BB84 System",
      "type": "coding",
      "difficulty": "advanced",
      "points": 35,
      "description": "Build end-to-end BB84 system simulation.",
      "tasks": [
        "Integrate all components (source, channel, detector)",
        "Include decoy states and timing",
        "Run full protocol (sifting, EC, PA)",
        "Calculate final secure key",
        "Generate performance report"
      ],
      "expectedOutput": "Complete BB84 system simulation",
      "hints": [
        "Chain all components together",
        "Track losses at each stage",
        "Include all QBER sources",
        "Report bits at each stage"
      ]
    },
    {
      "id": "ex4",
      "title": "System Performance Analyzer",
      "type": "coding",
      "difficulty": "intermediate",
      "points": 10,
      "description": "Analyze BB84 system performance across scenarios.",
      "tasks": [
        "Calculate key rate vs distance",
        "Find maximum operational distance",
        "Compare different detector types",
        "Optimize system parameters",
        "Generate performance curves"
      ],
      "expectedOutput": "BB84 performance analysis tool",
      "hints": [
