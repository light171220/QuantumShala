{
  "exerciseId": "07-06-05-applications-exercises",
  "title": "Exercises: Quantum Internet Applications",
  "exercises": [
    {
      "id": "ex1",
      "title": "QKD Rate Calculator",
      "type": "coding",
      "difficulty": "intermediate",
      "points": 25,
      "description": "Calculate secure key rates for QKD over quantum network.",
      "tasks": [
        "Model entanglement distribution rate",
        "Calculate raw key from measurements",
        "Estimate QBER from fidelity",
        "Apply error correction overhead",
        "Compute final secure key rate"
      ],
      "expectedOutput": "QKD rate estimation tool",
      "hints": [
        "Raw rate depends on entanglement generation",
        "QBER ≈ 1 - fidelity for depolarizing noise",
        "Error correction: ~1.2× overhead typical",
        "Privacy amplification: h(QBER) bits lost per raw bit"
      ]
    },
    {
      "id": "ex2",
      "title": "Blind Computation Simulator",
      "type": "coding",
      "difficulty": "advanced",
      "points": 30,
      "description": "Simulate the blind quantum computation protocol.",
      "tasks": [
        "Generate random rotation angles for user",
        "Prepare encoded qubits",
        "Simulate server operations (without learning)",
        "Apply measurement corrections",
        "Verify server learns nothing"
      ],
      "expectedOutput": "Blind computation protocol simulation",
      "hints": [
        "User prepares |+θ⟩ states with random θ",
        "Server entangles and measures",
        "User adjusts measurement angles for θ",
        "Final result only makes sense with user's key"
      ]
    },
    {
      "id": "ex3",
      "title": "Distributed Sensing Analyzer",
      "type": "coding",
      "difficulty": "intermediate",
      "points": 25,
      "description": "Analyze sensitivity improvements for quantum sensor networks.",
      "tasks": [
        "Model N classical sensors (shot noise)",
        "Model N entangled sensors (Heisenberg)",
        "Compare sensitivity scaling",
        "Include realistic noise and loss",
        "Determine break-even point"
      ],
      "expectedOutput": "Quantum sensing advantage analysis",
      "hints": [
        "Classical: σ ∝ 1/√N",
        "Quantum: σ ∝ 1/N (ideal)",
        "Real systems fall between limits",
        "Loss degrades quantum advantage"
      ]
    },
    {
      "id": "ex4",
      "title": "Application Requirements Mapper",
      "type": "coding",
      "difficulty": "beginner",
      "points": 20,
      "description": "Map quantum internet applications to network requirements.",
      "tasks": [
        "Define application categories",
        "List network requirements for each",
        "Map to network development stages",
        "Identify enabling technologies",
        "Generate application roadmap"
      ],
      "expectedOutput": "Application-requirements mapping tool",
      "hints": [
        "QKD needs basic quantum channel",
        "Distributed QC needs high-fidelity entanglement",
        "Sensing needs multi-party entanglement",
        "Some apps need quantum memory"
      ]
    }
  ]
}
