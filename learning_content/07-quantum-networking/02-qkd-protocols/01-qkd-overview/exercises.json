{
  "exerciseId": "07-02-01-qkd-overview-exercises",
  "title": "Exercises: QKD Overview",
  "exercises": [
    {
      "id": "ex1",
      "title": "QKD Protocol Simulator",
      "type": "coding",
      "difficulty": "intermediate",
      "points": 30,
      "description": "Build a complete QKD protocol simulator.",
      "tasks": [
        "Implement quantum bit transmission",
        "Add random basis selection for Alice and Bob",
        "Implement sifting phase",
        "Calculate QBER from sample",
        "Determine final key length"
      ],
      "expectedOutput": "End-to-end QKD simulation with statistics",
      "hints": [
        "Alice: random bits + random bases",
        "Bob: random bases → measure",
        "Sifting: keep matching basis bits",
        "Secret rate: 1 - 2h(e) for low error"
      ]
    },
    {
      "id": "ex2",
      "title": "Eavesdropper Analysis",
      "type": "coding",
      "difficulty": "intermediate",
      "points": 25,
      "description": "Model and analyze eavesdropping attacks.",
      "tasks": [
        "Implement intercept-resend attack",
        "Calculate introduced QBER",
        "Determine detection probability",
        "Compare with BB84 threshold",
        "Visualize Eve's information vs detection tradeoff"
      ],
      "expectedOutput": "Eavesdropping analysis tool",
      "hints": [
        "Wrong basis → 50% error",
        "Eve guesses correctly 50% of time",
        "Detection ~ 1 - (1-e)^n for n samples",
        "Information-disturbance tradeoff"
      ]
    },
    {
      "id": "ex3",
      "title": "Protocol Comparison Tool",
      "type": "coding",
      "difficulty": "beginner",
      "points": 25,
      "description": "Build a QKD protocol comparison database.",
      "tasks": [
        "Define protocol data structure",
        "Catalog major protocols (BB84, E91, etc.)",
        "Compare key properties",
        "Generate comparison tables",
        "Recommend protocol for use case"
      ],
      "expectedOutput": "Interactive protocol comparison tool",
      "hints": [
        "Track: type, bases, max QBER, efficiency",
        "Include prepare-measure and entanglement-based",
        "Consider practical factors",
        "Match to application requirements"
      ]
    },
    {
      "id": "ex4",
      "title": "Security Bound Calculator",
      "type": "coding",
      "difficulty": "advanced",
      "points": 20,
      "description": "Calculate security bounds for QKD.",
      "tasks": [
        "Implement binary entropy function",
        "Calculate Devetak-Winter bound",
        "Determine secure key rate vs QBER",
        "Find threshold QBER",
        "Plot secret fraction vs error rate"
      ],
      "expectedOutput": "Security bound visualization tool",
      "hints": [
        "h(p) = -p log p - (1-p) log(1-p)",
        "Secret rate = 1 - h(e) - h(e_p) for BB84",
        "Threshold when rate = 0",
        "Account for error correction overhead"
      ]
    }
  ]
}
