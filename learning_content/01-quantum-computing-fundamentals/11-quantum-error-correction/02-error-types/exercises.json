{
  "exerciseId": "01-11-02-error-types-exercises",
  "title": "Exercises: Quantum Error Types",
  "exercises": [
    {
      "id": "ex1",
      "title": "Pauli Error Effects",
      "type": "coding",
      "difficulty": "beginner",
      "points": 25,
      "description": "Visualize the effects of Pauli errors on quantum states.",
      "tasks": [
        "Define X, Y, Z Pauli matrices",
        "Apply each to states |0⟩, |1⟩, |+⟩, |-⟩",
        "Calculate resulting states",
        "Visualize on Bloch sphere",
        "Verify Y = iXZ relationship"
      ],
      "expectedOutput": "Pauli error visualization",
      "hints": [
        "X = [[0,1],[1,0]], Z = [[1,0],[0,-1]]",
        "Y = [[0,-i],[i,0]]",
        "|+⟩ = [1,1]/√2, |-⟩ = [1,-1]/√2",
        "Use qiskit visualization"
      ]
    },
    {
      "id": "ex2",
      "title": "Error Decomposition",
      "type": "coding",
      "difficulty": "intermediate",
      "points": 25,
      "description": "Decompose arbitrary errors into Pauli basis.",
      "tasks": [
        "Given arbitrary 2×2 matrix E",
        "Find coefficients c₀, c₁, c₂, c₃",
        "Verify E = c₀I + c₁X + c₂Y + c₃Z",
        "Apply to rotation matrices Rx(θ), Rz(θ)",
        "Interpret physical meaning"
      ],
      "expectedOutput": "Error decomposition tool",
      "hints": [
        "Use trace formula: cᵢ = Tr(PᵢE)/2",
        "Pauli matrices are orthogonal",
        "Rz(θ) = cos(θ/2)I - i·sin(θ/2)Z",
        "Check reconstruction"
      ]
    },
    {
      "id": "ex3",
      "title": "Noise Channel Simulator",
      "type": "coding",
      "difficulty": "intermediate",
      "points": 25,
      "description": "Simulate common quantum noise channels.",
      "tasks": [
        "Implement depolarizing channel",
        "Implement amplitude damping",
        "Implement dephasing channel",
        "Apply to various initial states",
        "Plot state evolution with noise"
      ],
      "expectedOutput": "Noise channel simulations",
      "hints": [
        "Use Kraus operators for each channel",
        "Track density matrix evolution",
        "Compare different noise strengths",
        "Visualize on Bloch sphere"
      ]
    },
    {
      "id": "ex4",
      "title": "Error Rate Analysis",
      "type": "coding",
      "difficulty": "intermediate",
      "points": 25,
      "description": "Analyze how different error types affect quantum algorithms.",
      "tasks": [
        "Create simple 3-gate circuit",
        "Add different error types after each gate",
        "Measure final state fidelity",
        "Compare X, Z, and depolarizing errors",
        "Find which algorithms are sensitive to which errors"
      ],
      "expectedOutput": "Error sensitivity analysis",
      "hints": [
        "Fidelity = |⟨ψ_ideal|ψ_noisy⟩|²",
        "Try Hadamard-based circuits",
        "Some gates are more error-sensitive",
        "Plot fidelity vs error rate"
      ]
    }
  ]
}
