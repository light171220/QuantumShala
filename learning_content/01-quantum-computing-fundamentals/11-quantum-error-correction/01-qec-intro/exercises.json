{
  "exerciseId": "01-11-01-qec-intro-exercises",
  "title": "Exercises: Introduction to Quantum Error Correction",
  "exercises": [
    {
      "id": "ex1",
      "title": "Error Accumulation Calculator",
      "type": "coding",
      "difficulty": "beginner",
      "points": 25,
      "description": "Calculate how errors accumulate in quantum circuits.",
      "tasks": [
        "Compute success probability for n gates at fidelity f",
        "Plot success vs number of gates",
        "Find number of gates before success drops to 50%",
        "Compare different fidelity levels",
        "Calculate required fidelity for 1000 gates at 90% success"
      ],
      "expectedOutput": "Error accumulation analysis",
      "hints": [
        "P(success) = f^n",
        "Use logarithms for large n",
        "matplotlib for plotting",
        "Solve f^1000 = 0.9 for f"
      ]
    },
    {
      "id": "ex2",
      "title": "No-Cloning Demonstration",
      "type": "coding",
      "difficulty": "intermediate",
      "points": 25,
      "description": "Show why cloning is impossible for arbitrary states.",
      "tasks": [
        "Assume cloning exists: U|ψ⟩|0⟩ = |ψ⟩|ψ⟩",
        "Apply to |0⟩ and |1⟩ separately",
        "Apply to |+⟩ = (|0⟩+|1⟩)/√2",
        "Show contradiction using linearity",
        "Explain why CNOT doesn't clone"
      ],
      "expectedOutput": "No-cloning proof",
      "hints": [
        "U must be linear",
        "Apply U to superposition",
        "Compare results",
        "CNOT(|ψ⟩|0⟩) vs |ψ⟩|ψ⟩"
      ]
    },
    {
      "id": "ex3",
      "title": "3-Qubit Code Simulator",
      "type": "coding",
      "difficulty": "intermediate",
      "points": 25,
      "description": "Simulate the 3-qubit bit flip code.",
      "tasks": [
        "Implement encoding: |ψ⟩ → |ψ_L⟩",
        "Apply random single-qubit X error",
        "Compute syndrome (parity checks)",
        "Determine which qubit had error",
        "Apply correction"
      ],
      "expectedOutput": "Working 3-qubit code",
      "hints": [
        "Encode with two CNOTs",
        "Syndrome: Z0Z1, Z1Z2",
        "4 syndromes → 4 cases",
        "Verify state is restored"
      ]
    },
    {
      "id": "ex4",
      "title": "Error Types Comparison",
      "type": "research",
      "difficulty": "beginner",
      "points": 25,
      "description": "Understand and compare quantum error types.",
      "tasks": [
        "List common quantum error sources",
        "Explain bit flip (X) error effect",
        "Explain phase flip (Z) error effect",
        "Explain Y error as combination",
        "Research why Pauli basis is complete"
      ],
      "expectedOutput": "Error types summary",
      "hints": [
        "X: |0⟩↔|1⟩, Z: |+⟩↔|-⟩",
        "Y = iXZ (up to phase)",
        "Any 2×2 matrix in Pauli span",
        "Decoherence causes which errors?"
      ]
    }
  ]
}
