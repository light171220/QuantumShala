{
  "exerciseId": "01-11-03-basic-codes-exercises",
  "title": "Exercises: Basic Quantum Codes",
  "exercises": [
    {
      "id": "ex1",
      "title": "Bit Flip Code Implementation",
      "type": "coding",
      "difficulty": "intermediate",
      "points": 25,
      "description": "Implement the complete 3-qubit bit flip code.",
      "tasks": [
        "Build encoding circuit with 2 CNOTs",
        "Apply random X error to one qubit",
        "Implement syndrome measurement",
        "Determine error location from syndrome",
        "Apply correction and verify"
      ],
      "expectedOutput": "Working bit flip code",
      "hints": [
        "Encode: CNOT q0→q1, CNOT q0→q2",
        "Syndrome: measure Z0Z1, Z1Z2",
        "Use ancilla qubits for syndrome",
        "Verify final state matches input"
      ]
    },
    {
      "id": "ex2",
      "title": "Phase Flip Code Conversion",
      "type": "coding",
      "difficulty": "intermediate",
      "points": 25,
      "description": "Convert bit flip code to phase flip code.",
      "tasks": [
        "Add Hadamards after encoding",
        "Show Z errors become 'bit flips' in H basis",
        "Implement X-basis syndrome measurement",
        "Correct Z errors",
        "Compare to bit flip code"
      ],
      "expectedOutput": "Working phase flip code",
      "hints": [
        "H transforms X↔Z",
        "Measure X0X1 instead of Z0Z1",
        "Same structure, different basis",
        "Apply Z correction (not X)"
      ]
    },
    {
      "id": "ex3",
      "title": "Shor Code Encoder",
      "type": "coding",
      "difficulty": "advanced",
      "points": 25,
      "description": "Build the 9-qubit Shor code encoder.",
      "tasks": [
        "Implement phase flip encoding first",
        "Add bit flip encoding to each block",
        "Verify correct logical state",
        "Count total gates used",
        "Test with superposition input"
      ],
      "expectedOutput": "9-qubit encoded state",
      "hints": [
        "First CNOT 1→4, 1→7",
        "Then H on 1, 4, 7",
        "Bit encode each block separately",
        "Check GHZ-like structure"
      ]
    },
    {
      "id": "ex4",
      "title": "Error Correction Comparison",
      "type": "coding",
      "difficulty": "advanced",
      "points": 25,
      "description": "Compare error correction capabilities of different codes.",
      "tasks": [
        "Implement bit flip, phase flip, and Shor codes",
        "Apply X, Z, and Y errors to each",
        "Track which errors are correctable",
        "Create comparison table",
        "Analyze overhead vs capability"
      ],
      "expectedOutput": "Code comparison analysis",
      "hints": [
        "Y = iXZ, test separately",
        "Shor should correct all single errors",
        "Bit flip fails on Z, phase flip on X",
        "Document failure modes"
      ]
    }
  ]
}
