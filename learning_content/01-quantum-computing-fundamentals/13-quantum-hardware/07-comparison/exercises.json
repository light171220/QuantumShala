    {"id": "ex1", "title": "Platform Selection Tool", "type": "coding", "difficulty": "intermediate", "points": 25, "description": "Build a tool to recommend platforms for applications.", "tasks": ["Define platform capability vectors", "Input application requirements", "Score platforms against requirements", "Rank platforms by fit", "Explain trade-offs for top choices"], "expectedOutput": "Platform recommendation system", "hints": ["Weight factors by importance", "Consider: qubits, fidelity, speed, connectivity", "Some requirements are binary", "Show pros and cons"]},
    {"id": "ex2", "title": "Circuit Depth Estimator", "type": "coding", "difficulty": "intermediate", "points": 25, "description": "Estimate achievable circuit depth across platforms.", "tasks": ["Input platform coherence and gate times", "Calculate max gates before decoherence", "Account for two-qubit gate overhead", "Compare across platforms", "Include connectivity impact"], "expectedOutput": "Depth comparison analysis", "hints": ["Depth = T₂ / t_gate", "Add SWAP overhead for limited connectivity", "Quality × quantity trade-off", "Consider error accumulation"]},
    {"id": "ex3", "title": "Algorithm-Platform Matcher", "type": "research", "difficulty": "intermediate", "points": 25, "description": "Match algorithms to optimal platforms.", "tasks": ["List 5 quantum algorithms", "Identify key requirements for each", "Match to best platform(s)", "Explain reasoning", "Note when multiple platforms work"], "expectedOutput": "Algorithm matching report", "hints": ["Consider: VQE, QAOA, Shor's, simulation, sampling", "Requirements: depth, qubits, fidelity, connectivity", "Some algorithms fit multiple", "Future vs current capabilities"]},
    {"id": "ex4", "title": "Scaling Trajectory Analyzer", "type": "coding", "difficulty": "advanced", "points": 25, "description": "Project platform scaling over time.", "tasks": ["Gather historical qubit counts", "Fit growth models (linear, exponential)", "Project forward 5 years", "Compare platforms", "Identify crossover points"], "expectedOutput": "Scaling projections", "hints": ["Use published roadmaps", "Consider error rate trends too", "Exponential may not sustain", "Fault-tolerance thresholds matter"]}
  ]
