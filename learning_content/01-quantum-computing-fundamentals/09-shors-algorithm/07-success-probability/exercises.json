{
  "exerciseId": "01-09-07-success-probability-exercises",
  "title": "Exercises: Success Probability Analysis",
  "exercises": [
    {
      "id": "ex1",
      "title": "Continued Fractions Calculator",
      "type": "coding",
      "difficulty": "intermediate",
      "points": 25,
      "description": "Implement the continued fractions algorithm for period extraction.",
      "tasks": [
        "Compute continued fraction expansion",
        "Generate all convergents",
        "Extract denominator as period candidate",
        "Verify candidate against a^r mod N = 1",
        "Handle edge cases"
      ],
      "expectedOutput": "Period from measurement outcome",
      "hints": [
        "Floor(x) gives next CF coefficient",
        "Track numerator and denominator recursively",
        "p_n = a_n*p_{n-1} + p_{n-2}",
        "Check each convergent denominator"
      ]
    },
    {
      "id": "ex2",
      "title": "Success Probability Simulator",
      "type": "coding",
      "difficulty": "intermediate",
      "points": 25,
      "description": "Simulate Shor's algorithm success rate empirically.",
      "tasks": [
        "Model measurement outcome distribution",
        "Apply continued fractions extraction",
        "Check period-to-factor success",
        "Run many trials",
        "Calculate empirical success rate"
      ],
      "expectedOutput": "Empirical success probability",
      "hints": [
        "Sample from peaked distribution",
        "Use small N for testing",
        "Track different failure modes",
        "Compare to theoretical predictions"
      ]
    },
    {
      "id": "ex3",
      "title": "Repetition Analysis",
      "type": "coding",
      "difficulty": "intermediate",
      "points": 25,
      "description": "Analyze how many repetitions are needed for high success.",
      "tasks": [
        "Calculate P(success after k runs)",
        "Plot success vs number of runs",
        "Find k for 90%, 99%, 99.9% success",
        "Compare different per-run probabilities",
        "Create lookup table"
      ],
      "expectedOutput": "Repetition requirement analysis",
      "hints": [
        "P(success) = 1 - (1-p)^k",
        "Solve for k given target P",
        "k = log(1-P)/log(1-p)",
        "Visualize with matplotlib"
      ]
    },
    {
      "id": "ex4",
      "title": "Multi-Measurement Combination",
      "type": "coding",
      "difficulty": "advanced",
      "points": 25,
      "description": "Combine multiple measurements to improve period extraction.",
      "tasks": [
        "Take multiple measurement outcomes",
        "Extract period candidates from each",
        "Compute LCM of valid candidates",
        "Verify combined period",
        "Analyze improvement over single measurement"
      ],
      "expectedOutput": "Combined period extraction",
      "hints": [
        "LCM often gives true period",
        "Filter invalid candidates first",
        "Handle divisors of true period",
        "More measurements = higher confidence"
      ]
    }
  ]
