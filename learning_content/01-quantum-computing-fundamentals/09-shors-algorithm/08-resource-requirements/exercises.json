{
  "exerciseId": "01-09-08-resource-requirements-exercises",
  "title": "Exercises: Resource Requirements",
  "exercises": [
    {
      "id": "ex1",
      "title": "Resource Calculator",
      "type": "coding",
      "difficulty": "intermediate",
      "points": 25,
      "description": "Build a comprehensive resource calculator for Shor's algorithm.",
      "tasks": [
        "Calculate logical qubits for n-bit factoring",
        "Estimate gate count (T gates, Toffoli)",
        "Compute physical qubits with surface code",
        "Include magic state factory overhead",
        "Output formatted resource summary"
      ],
      "expectedOutput": "Resource estimation report",
      "hints": [
        "Control: 2n, Target: n, Ancilla: ~2n",
        "Gates: O(n³), about 2n³ Toffolis",
        "Physical: 2d² per logical (d≈27)",
        "Factories: ~10% additional qubits"
      ]
    },
    {
      "id": "ex2",
      "title": "Gap Analysis Tool",
      "type": "coding",
      "difficulty": "intermediate",
      "points": 25,
      "description": "Compare current quantum computers to Shor's requirements.",
      "tasks": [
        "Input current hardware specs",
        "Input target key size",
        "Calculate gap for each metric",
        "Visualize on log scale",
        "Estimate years to close gap"
      ],
      "expectedOutput": "Gap analysis visualization",
      "hints": [
        "Track qubits, fidelity, connectivity",
        "Use logarithmic scaling for large gaps",
        "Historical progress: ~2× qubits/year",
        "Consider multiple metrics"
      ]
    },
    {
      "id": "ex3",
      "title": "Optimization Impact Analyzer",
      "type": "coding",
      "difficulty": "advanced",
      "points": 25,
      "description": "Analyze how different optimizations affect resource requirements.",
      "tasks": [
        "Implement baseline resource model",
        "Add toggles for optimizations",
        "Calculate savings from each",
        "Identify most impactful optimizations",
        "Plot combined effects"
      ],
      "expectedOutput": "Optimization impact comparison",
      "hints": [
        "Beauregard: 5n → 2n+3 qubits",
        "Approximate QFT: 10-100× fewer rotations",
        "Windowed exp: reduce by factor w",
        "Optimizations may interact"
      ]
    },
    {
      "id": "ex4",
      "title": "Cryptographic Timeline Estimator",
      "type": "research",
      "difficulty": "advanced",
      "points": 25,
      "description": "Estimate when quantum computers might threaten current cryptography.",
      "tasks": [
        "Research current qubit counts and progress rate",
        "Model exponential vs linear growth",
        "Project time to reach RSA-2048 requirements",
        "Consider multiple scenarios",
        "Discuss implications for cryptographic migration"
      ],
      "expectedOutput": "Timeline projection report",
      "hints": [
        "Consider physical and logical progress",
        "Error rates must also improve",
        "Conservative vs optimistic scenarios",
        "Factor in engineering challenges"
      ]
    }
  ]
