{
  "exerciseId": "01-09-09-cryptographic-implications-exercises",
  "title": "Exercises: Cryptographic Implications",
  "exercises": [
    {
      "id": "ex1",
      "title": "Vulnerability Assessment Tool",
      "type": "coding",
      "difficulty": "intermediate",
      "points": 25,
      "description": "Build a tool to assess cryptographic vulnerability to quantum attacks.",
      "tasks": [
        "Input: algorithm name and key size",
        "Classify as broken, weakened, or safe",
        "Recommend quantum-resistant alternative",
        "Calculate effective security level",
        "Output vulnerability report"
      ],
      "expectedOutput": "Quantum vulnerability assessment",
      "hints": [
        "RSA/ECC/DH: completely broken",
        "AES: divide key bits by 2",
        "Map to PQC alternatives",
        "Consider NIST standards"
      ]
    },
    {
      "id": "ex2",
      "title": "HNDL Risk Calculator",
      "type": "coding",
      "difficulty": "intermediate",
      "points": 25,
      "description": "Calculate harvest-now-decrypt-later risk for different data types.",
      "tasks": [
        "Input: data sensitivity period (years)",
        "Input: estimated quantum timeline",
        "Calculate risk window",
        "Classify risk level",
        "Recommend protection urgency"
      ],
      "expectedOutput": "HNDL risk assessment",
      "hints": [
        "Risk if sensitivity > quantum timeline",
        "Consider best/worst case timelines",
        "Factor in data value",
        "Output actionable recommendations"
      ]
    },
    {
      "id": "ex3",
      "title": "Migration Roadmap Generator",
      "type": "coding",
      "difficulty": "advanced",
      "points": 25,
      "description": "Create a customized PQC migration roadmap for an organization.",
      "tasks": [
        "Input: current crypto inventory",
        "Identify vulnerable components",
        "Prioritize by risk and difficulty",
        "Generate phased migration plan",
        "Estimate resources needed"
      ],
      "expectedOutput": "Migration roadmap document",
      "hints": [
        "Phase 1: Inventory, Phase 2: Hybrid",
        "Prioritize long-lived secrets",
        "Consider dependencies",
        "Include testing milestones"
      ]
    },
    {
      "id": "ex4",
      "title": "Hybrid Encryption Demo",
      "type": "coding",
      "difficulty": "advanced",
      "points": 25,
      "description": "Implement a hybrid classical/post-quantum encryption scheme.",
      "tasks": [
        "Implement classical key exchange (DH/ECDH simulation)",
        "Add post-quantum KEM (simulate Kyber)",
        "Combine keys securely (XOR or KDF)",
        "Encrypt message with derived key",
        "Demonstrate security of hybrid approach"
      ],
      "expectedOutput": "Working hybrid encryption demo",
      "hints": [
        "Final key = Hash(classical || pqc)",
        "Either key protects the message",
        "Use established KDFs",
        "Show that breaking one doesn't help"
      ]
    }
  ]
}
