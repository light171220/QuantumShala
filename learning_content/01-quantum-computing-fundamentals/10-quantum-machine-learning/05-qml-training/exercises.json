{
  "exerciseId": "01-10-05-qml-training-exercises",
  "title": "Exercises: Training Quantum Models",
  "exercises": [
    {
      "id": "ex1",
      "title": "Parameter Shift Implementation",
      "type": "coding",
      "difficulty": "intermediate",
      "points": 25,
      "description": "Implement gradient computation using parameter shift rule.",
      "tasks": [
        "Create function to evaluate expectation",
        "Implement parameter shift gradient for one parameter",
        "Extend to full gradient vector",
        "Verify against finite difference",
        "Count circuit evaluations"
      ],
      "expectedOutput": "Working gradient computation",
      "hints": [
        "Shift by ±π/2 for Pauli rotations",
        "grad = (f(θ+π/2) - f(θ-π/2)) / 2",
        "Full gradient needs 2m evaluations",
        "Compare to numerical gradient"
      ]
    },
    {
      "id": "ex2",
      "title": "Optimizer Comparison",
      "type": "coding",
      "difficulty": "intermediate",
      "points": 25,
      "description": "Compare different optimizers on a simple VQE problem.",
      "tasks": [
        "Set up simple Hamiltonian",
        "Implement gradient descent",
        "Add Adam optimizer",
        "Try COBYLA (gradient-free)",
        "Compare convergence speed"
      ],
      "expectedOutput": "Optimizer comparison plots",
      "hints": [
        "Use H = Z0 + 0.5*X0 for testing",
        "Track loss over iterations",
        "Same initialization for fairness",
        "Plot convergence curves"
      ]
    },
    {
      "id": "ex3",
      "title": "Shot Noise Simulator",
      "type": "coding",
      "difficulty": "advanced",
      "points": 25,
      "description": "Simulate training with realistic shot noise.",
      "tasks": [
        "Add shot noise to expectation values",
        "Train with different shot budgets",
        "Compare fixed vs adaptive shots",
        "Measure final accuracy vs shots used",
        "Find optimal shot allocation"
      ],
      "expectedOutput": "Shot noise analysis",
      "hints": [
        "σ ≈ 1/√(n_shots)",
        "Add Gaussian noise to simulate",
        "Adaptive: increase shots over time",
        "Plot accuracy vs total shots"
      ]
    },
    {
      "id": "ex4",
      "title": "SPSA Optimizer",
      "type": "coding",
      "difficulty": "advanced",
      "points": 25,
      "description": "Implement SPSA optimizer for quantum circuits.",
      "tasks": [
        "Implement SPSA gradient estimate",
        "Only use 2 circuit evaluations per step",
        "Add proper learning rate schedule",
        "Compare to parameter shift training",
        "Test under high noise"
      ],
      "expectedOutput": "Working SPSA implementation",
      "hints": [
        "Random ±1 perturbation vector",
        "grad ≈ (f(θ+cΔ) - f(θ-cΔ)) / (2c) * Δ",
        "Decay c and learning rate",
        "Average multiple runs"
      ]
    }
  ]
}
