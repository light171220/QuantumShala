      "difficulty": "advanced",
      "points": 25,
      "description": "Compute the expressibility of a variational circuit.",
      "tasks": [
        "Generate random parameter sets",
        "Compute fidelities between random states",
        "Compare to Haar-random distribution",
        "Calculate expressibility metric",
        "Compare different ansätze"
      ],
      "expectedOutput": "Expressibility comparison",
      "hints": [
        "Sample many random parameter vectors",
        "Fidelity = |⟨ψ₁|ψ₂⟩|²",
        "Haar random: specific fidelity distribution",
        "KL divergence or similar metric"
      ]
    },
    {
      "id": "ex3",
      "title": "Barren Plateau Detector",
      "type": "coding",
      "difficulty": "advanced",
      "points": 25,
      "description": "Detect barren plateaus by measuring gradient variance.",
      "tasks": [
        "Compute gradients at random points",
