        "Identify when plateaus occur"
      ],
      "expectedOutput": "Barren plateau analysis",
      "hints": [
        "Use parameter shift for gradients",
        "Sample many random initializations",
        "Variance should decay exponentially",
        "Log scale for visualization"
      ]
    },
