      "id": "ex1",
      "title": "Hardware Efficient Ansatz",
      "type": "coding",
      "difficulty": "intermediate",
      "points": 25,
      "description": "Build a configurable hardware efficient ansatz.",
      "tasks": [
        "Implement rotation layer (Ry, Rz on each qubit)",
        "Add linear CNOT entangling layer",
        "Stack multiple layers",
        "Make depth configurable",
        "Count total parameters"
      ],
      "expectedOutput": "Parameterized HEA circuit",
      "hints": [
        "Each layer: Ry, Rz per qubit + CNOTs",
        "Linear CNOT: chain from qubit 0 to n-1",
        "Parameters = 2 * n_qubits * n_layers",
        "Use circuit.draw() to visualize"
      ]
    },
    {
